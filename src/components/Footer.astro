---
// Footer.astro
const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-inner">
      <div>
        <a href="/" class="footer-brand" aria-label="Chandra Kanojia — Home">
          Chandra Kanojia
        </a>
        <p class="footer-descriptor">
          Enterprise AI and transformation leadership. Fortune 100 financial services.
          Operating-model redesign at scale.
        </p>
      </div>

      <nav class="footer-links" aria-label="Footer navigation">
        <a href="/executive-profile">Executive Profile</a>
        <a href="/enterprise-ai-transformation">Enterprise AI</a>
        <a href="/insights">Insights</a>
        <a href="/contact">Contact</a>
        <a href="/privacy">Privacy</a>
        <a
          href="https://www.linkedin.com/in/chandra-kanojia/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Chandra Kanojia on LinkedIn (opens in new tab)"
        >
          LinkedIn ↗
        </a>
      </nav>
    </div>

    <div class="footer-bottom">
      <span class="footer-legal">
        © {year} Chandra Kanojia. All rights reserved.
      </span>
      <span class="footer-legal">
        IIM Bangalore · Carnegie Mellon · NIT Allahabad
      </span>
    </div>
  </div>
</footer>
