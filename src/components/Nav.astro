---
const navLinks = [
  { href: '/executive-profile', label: 'Profile' },
  { href: '/enterprise-ai-transformation', label: 'Enterprise AI' },
  { href: '/insights', label: 'Field Notes' },
  { href: '/executive-briefings', label: 'Briefings' },
];
const currentPath = Astro.url.pathname;
---
<nav class="site-nav" role="navigation" aria-label="Main navigation">
  <div class="container">
    <div class="nav-inner">
      <a href="/" class="nav-wordmark" aria-label="Chandra Kanojia — Home">
        <span class="identity-mark" aria-hidden="true"><span></span></span>
        Chandra Kanojia
      </a>
      <button id="mobile-nav-toggle" class="nav-mobile-toggle" aria-expanded="false" aria-controls="nav-links-wrapper" aria-label="Open navigation menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M3 6h14M3 10h14M3 14h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <div id="nav-links-wrapper" class="nav-links-wrapper">
        <ul class="nav-links" role="list">
          {navLinks.map(link => (
            <li><a href={link.href} aria-current={currentPath === link.href ? 'page' : undefined}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="nav-right">
        <a class="nav-cta" href="https://www.linkedin.com/in/chandra-kanojia/" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
      </div>
    </div>
  </div>
</nav>
