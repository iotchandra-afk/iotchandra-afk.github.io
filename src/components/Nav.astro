---
// Nav.astro — Sticky, accessible, keyboard-navigable navigation
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/executive-profile', label: 'Profile' },
  { href: '/enterprise-ai-transformation', label: 'Enterprise AI' },
  { href: '/insights', label: 'Insights' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<nav class="site-nav" role="navigation" aria-label="Main navigation">
  <div class="container">
    <div class="nav-inner">
      <a href="/" class="nav-wordmark" aria-label="Chandra Kanojia — Home">
        Chandra Kanojia
      </a>

      <button
        id="mobile-nav-toggle"
        class="nav-mobile-toggle"
        aria-expanded="false"
        aria-controls="nav-links-wrapper"
        aria-label="Open navigation menu"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M3 6h14M3 10h14M3 14h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>

      <div id="nav-links-wrapper" class="nav-links-wrapper">
        <ul class="nav-links" role="list">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                aria-current={currentPath === link.href ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="nav-right">
        <button
          id="theme-toggle"
          class="theme-toggle"
          aria-label="Switch to dark mode"
          title="Toggle color mode"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg class="icon-sun" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="3.5" stroke="currentColor" stroke-width="1.25"/>
            <path d="M8 1v1.5M8 13.5V15M15 8h-1.5M2.5 8H1M12.95 3.05l-1.06 1.06M4.11 11.89l-1.06 1.06M12.95 12.95l-1.06-1.06M4.11 4.11l-1.06-1.06"
              stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg class="icon-moon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M13.5 10A6 6 0 016 2.5a6 6 0 100 11A6 6 0 0013.5 10z"
              stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
          </svg>
        </button>

        <a href="/contact" class="nav-cta">
          Contact
        </a>
      </div>
    </div>
  </div>
</nav>
