---
const {
  id = 'discuss-mandate',
  eyebrow = 'Discuss the mandate',
  title = 'The useful conversation starts after the demo.',
  body = 'Talk to Chandra about making AI work inside regulated environments: trusted data, CRM/Salesforce, workflow, controls, adoption, and measurable business value.',
  buttonText = 'Connect on LinkedIn',
  href = 'https://www.linkedin.com/in/chandra-kanojia/'
} = Astro.props;
---
<section class="cta-section" aria-labelledby={id}>
  <div class="container">
    <div class="cta-box mandate-cta compact-cta">
      <div class="cta-copy">
        <p class="cta-label">{eyebrow}</p>
        <h2 id={id}>{title}</h2>
        <p>{body}</p>
      </div>
      <a class="button" href={href} target="_blank" rel="noopener noreferrer">{buttonText}</a>
    </div>
  </div>
</section>
