---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: object | object[];
  noIndex?: boolean;
}

const { title, description, canonical, ogImage = '/images/og-default.png', jsonLd, noIndex = false } = Astro.props;
const siteUrl = 'https://www.chandrakanojia.com';
const canonicalUrl = canonical ? canonical : `${siteUrl}${Astro.url.pathname}`;
const fullTitle = title.includes('Chandra Kanojia') ? title : `${title} | Chandra Kanojia`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${siteUrl}/#chandra-kanojia`,
  name: 'Chandra Kanojia',
  url: siteUrl,
  description: 'Chandra Kanojia is an enterprise AI and platform transformation executive focused on governed workflows, CRM, operating intelligence, and financial services transformation.',
  jobTitle: 'Enterprise AI and Platform Transformation Executive',
  alumniOf: [
    { '@type': 'EducationalOrganization', name: 'Indian Institute of Management Bangalore' },
    { '@type': 'EducationalOrganization', name: 'Carnegie Mellon University', description: 'CIO Program' },
    { '@type': 'EducationalOrganization', name: 'National Institute of Technology Allahabad' }
  ],
  knowsAbout: [
    'Enterprise AI Transformation',
    'AI Governance',
    'Data Readiness for AI',
    'Trusted Data and Decision Context',
    'CRM and Salesforce Modernization',
    'Enterprise Workflow Transformation',
    'Systems of Action',
    'Controlled Autonomy',
    'Platform Reliability',
    'Regulated Financial Services Transformation',
    'Operating Model Transformation',
    'Case Management Platforms',
    'Advisor and Associate Enablement',
    'Executive Briefings on AI'
  ],
  sameAs: ['https://www.linkedin.com/in/chandra-kanojia/']
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  name: 'Chandra Kanojia',
  url: siteUrl,
  description: 'Professional site covering enterprise AI, data readiness, CRM/Salesforce, workflow, evidence, controls, executive briefings, and regulated operating change.',
  author: { '@id': `${siteUrl}/#chandra-kanojia` },
  publisher: { '@id': `${siteUrl}/#chandra-kanojia` }
};

const allSchemas = [personSchema, websiteSchema, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Chandra Kanojia" />
  <meta property="og:locale" content="en_US" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
  <script type="application/ld+json" set:html={JSON.stringify(allSchemas)} />
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <div class="site-wrapper">
    <slot name="nav" />
    <main id="main-content" tabindex="-1"><slot /></main>
    <slot name="footer" />
  </div>
  <script>
    const mobileToggle = document.getElementById('mobile-nav-toggle');
    const navWrapper = document.getElementById('nav-links-wrapper');
    if (mobileToggle && navWrapper) {
      mobileToggle.addEventListener('click', () => {
        const expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
        mobileToggle.setAttribute('aria-expanded', String(!expanded));
        navWrapper.classList.toggle('open');
      });
    }

    document.querySelectorAll('[data-copy-text]').forEach((button) => {
      button.addEventListener('click', async () => {
        const text = button.getAttribute('data-copy-text');
        if (!text) return;
        const original = button.textContent;
        try {
          await navigator.clipboard.writeText(text);
          button.textContent = 'Copied';
          button.setAttribute('aria-live', 'polite');
          setTimeout(() => { button.textContent = original; }, 1800);
        } catch (error) {
          button.textContent = 'Copy failed';
          setTimeout(() => { button.textContent = original; }, 1800);
        }
      });
    });
  </script>
</body>
</html>
