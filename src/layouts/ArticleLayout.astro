---
import PageLayout from './PageLayout.astro';

interface Props {
  title: string;
  lede: string;
  pillar: string;
  date: string;
  slug: string;
  readTime?: string;
  updated?: string;
  briefing?: {
    about: string;
    matters: string;
    question: string;
  };
}
const { title, lede, pillar, date, slug, readTime = '4 min read', updated = 'June 2026', briefing } = Astro.props;
const siteUrl = 'https://www.chandrakanojia.com';
const canonicalUrl = `${siteUrl}/insights/${slug}`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${canonicalUrl}#article`,
  headline: title,
  description: lede,
  url: canonicalUrl,
  datePublished: `${date}-01-01`,
  dateModified: updated.includes('2026') ? '2026-06-01' : `${date}-01-01`,
  author: { '@id': `${siteUrl}/#chandra-kanojia` },
  publisher: { '@id': `${siteUrl}/#website` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Field Notes', item: `${siteUrl}/insights` },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl }
  ]
};
---
<PageLayout title={`${title} | Chandra Kanojia`} description={lede} canonical={canonicalUrl} ogImage={`/images/og-${slug}.png`} jsonLd={[articleSchema, breadcrumbSchema]}>
  <section class="article-header" aria-labelledby="article-title">
    <div class="container prose-container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb" role="list">
          <li><a href="/">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/insights">Field Notes</a></li>
        </ol>
      </nav>
      <div class="article-meta"><span>{pillar}</span><span>{readTime}</span><span>Updated {updated}</span></div>
      <h1 id="article-title" class="article-title">{title}</h1>
      <p class="article-lede">{lede}</p>
      {briefing && (
        <aside class="briefing-panel" aria-label="Executive briefing">
          <div class="briefing-panel-head">
            <p class="briefing-eyebrow">Executive briefing</p>
            <p>A fast read before the full note.</p>
          </div>
          <div class="briefing-items">
            <div>
              <span>What this note is about</span>
              <p>{briefing.about}</p>
            </div>
            <div>
              <span>Why it matters</span>
              <p>{briefing.matters}</p>
            </div>
            <div>
              <span>Question to ask</span>
              <p>{briefing.question}</p>
            </div>
          </div>
        </aside>
      )}
    </div>
  </section>
  <section class="article-body">
    <div class="container prose-container">
      <article class="prose"><slot /></article>
      <div class="author-block" aria-label="Author information">
        <p class="author-label">Author</p>
        <p class="author-name">Chandra Kanojia</p>
        <p class="author-bio">Chandra Kanojia is an enterprise AI and platform transformation executive focused on governed workflows, CRM, operating intelligence, and financial services transformation.</p>
      </div>
    </div>
  </section>
</PageLayout>
