---
import PageLayout from './PageLayout.astro';

interface Props {
  title: string;
  lede: string;
  pillar: string;
  date: string;
  slug: string;
}
const { title, lede, pillar, date, slug } = Astro.props;
const siteUrl = 'https://chandrakanojia.com';
const canonicalUrl = `${siteUrl}/insights/${slug}`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: lede,
  url: canonicalUrl,
  datePublished: `${date}-01-01`,
  dateModified: `${date}-01-01`,
  author: { '@id': `${siteUrl}/#person` },
  publisher: { '@id': `${siteUrl}/#website` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Insights', item: `${siteUrl}/insights` },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl }
  ]
};
---
<PageLayout title={`${title} | Chandra Kanojia`} description={lede} canonical={canonicalUrl} jsonLd={[articleSchema, breadcrumbSchema]}>
  <section class="article-header" aria-labelledby="article-title">
    <div class="container prose-container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb" role="list">
          <li><a href="/">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/insights">Insights</a></li>
        </ol>
      </nav>
      <div class="article-meta"><span>{pillar}</span><span>{date}</span></div>
      <h1 id="article-title" class="article-title">{title}</h1>
      <p class="article-lede">{lede}</p>
    </div>
  </section>
  <section class="article-body">
    <div class="container prose-container">
      <article class="prose"><slot /></article>
      <div class="author-block" aria-label="Author information">
        <p class="author-label">Author</p>
        <p class="author-name">Chandra Kanojia</p>
        <p class="author-bio">Enterprise AI and transformation operator focused on CRM/Salesforce, workflow, regulated operating models, and governed execution.</p>
      </div>
    </div>
  </section>
</PageLayout>
