---
import PageLayout from '../layouts/PageLayout.astro';
import DiscussCTA from '../components/DiscussCTA.astro';

const webpageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': 'https://www.chandrakanojia.com/executive-briefings/#profilepage',
  url: 'https://www.chandrakanojia.com/executive-briefings',
  name: 'Enterprise AI Speaker and Executive Briefings | Chandra Kanojia',
  description: 'Executive briefings on enterprise AI, data readiness, CRM/Salesforce, workflow transformation, controlled autonomy, and regulated operating change.',
  mainEntity: { '@id': 'https://www.chandrakanojia.com/#person' },
  about: [
    'Enterprise AI speaker',
    'AI governance speaker',
    'Data readiness for AI',
    'CRM transformation',
    'Regulated enterprise AI'
  ]
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.chandrakanojia.com' },
    { '@type': 'ListItem', position: 2, name: 'Executive Briefings', item: 'https://www.chandrakanojia.com/executive-briefings' }
  ]
};
---
<PageLayout
  title="Enterprise AI Speaker & Executive Briefings | Chandra Kanojia"
  description="Executive briefings on enterprise AI, data readiness, CRM/Salesforce, workflow transformation, controlled autonomy, and regulated operating change."
  canonical="https://www.chandrakanojia.com/executive-briefings"
  ogImage="/images/og-briefings.png"
  jsonLd={[webpageSchema, breadcrumbSchema]}
>
  <section class="page-hero" aria-labelledby="briefings-title">
    <div class="container narrow">
      <p class="kicker">Executive Briefings</p>
      <h1 id="briefings-title">The useful AI conversation has moved past demos.</h1>
      <p class="lead">
        Boards and executive teams are now asking a harder question: can the enterprise change the work, trust the data, control the risk, and make AI matter at scale?
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="topics-title">
    <div class="container">
      <div class="section-heading compact-heading">
        <p class="kicker">Briefing themes</p>
        <h2 id="topics-title">Topics built for boards, CXOs, technology leaders, and transformation teams.</h2>
      </div>
      <div class="mandate-grid briefing-grid">
        <article class="mandate-card">
          <span>01</span>
          <h3>AI after the demo</h3>
          <p>What changes when AI moves from assistance to execution, and why tool rollout is not the same as operating change.</p>
        </article>
        <article class="mandate-card">
          <span>02</span>
          <h3>The data problem under AI strategy</h3>
          <p>Why trusted context at the point of work matters more than another data platform or dashboard.</p>
        </article>
        <article class="mandate-card">
          <span>03</span>
          <h3>Controlled autonomy</h3>
          <p>How enterprises decide what AI can do, when a human returns, and how accountability is preserved.</p>
        </article>
        <article class="mandate-card">
          <span>04</span>
          <h3>CRM as a system of action</h3>
          <p>Why the next CRM advantage is not better data capture, but better decisions and follow-through.</p>
        </article>
        <article class="mandate-card">
          <span>05</span>
          <h3>Enterprise AI in regulated environments</h3>
          <p>How financial services, insurance, retirement, healthcare, and other regulated businesses can move faster without losing trust.</p>
        </article>
        <article class="mandate-card">
          <span>06</span>
          <h3>AI, workflow, and operating leverage</h3>
          <p>Where AI creates capacity, reduces friction, improves experience, and changes how leaders manage work.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section alt" aria-labelledby="audience-title">
    <div class="container two-column-feature">
      <div class="section-heading compact-heading">
        <p class="kicker">Audience fit</p>
        <h2 id="audience-title">Built for serious rooms.</h2>
        <p>
          This is not a generic AI keynote. The focus is what leaders need to decide when AI begins to touch work, data, controls, customers, and operating outcomes.
        </p>
      </div>
      <div class="content-stack">
        <article class="content-panel"><h3>Boards and executive committees</h3><p>AI governance, risk, data trust, capital allocation, operating resilience, and management accountability.</p></article>
        <article class="content-panel"><h3>CIO / CAIO / CDO teams</h3><p>AI execution, trusted context, workflow integration, autonomy boundaries, and platform reliability.</p></article>
        <article class="content-panel"><h3>Business, consulting, and transformation leaders</h3><p>Customer and service operations, CRM modernization, advisor productivity, operating leverage, and delivery confidence.</p></article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="formats-title">
    <div class="container">
      <div class="authority-band">
        <p class="band-label" id="formats-title">Formats</p>
        <p>
          Executive briefing · board education session · leadership offsite keynote · strategy workshop · panel or fireside chat · private advisory conversation.
        </p>
      </div>
    </div>
  </section>
  <DiscussCTA
    id="briefings-cta"
    eyebrow="Discuss a briefing"
    title="Useful sessions help leaders see what has to change."
    body="For board, CXO, executive search, consulting, enterprise AI, and regulated-transformation conversations, connect directly on LinkedIn."
  />
</PageLayout>
