---
import PageLayout from '../layouts/PageLayout.astro';

const workbenchSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  '@id': 'https://www.chandrakanojia.com/enterprise-ai-workbench/#workbench',
  url: 'https://www.chandrakanojia.com/enterprise-ai-workbench',
  name: 'Enterprise AI Workbench',
  description: 'A reserved modular page for an executive-safe AI demonstration focused on enterprise AI, data readiness, workflow, controls, and decision quality.',
  creator: { '@id': 'https://www.chandrakanojia.com/#person' },
  isPartOf: { '@id': 'https://www.chandrakanojia.com/#website' },
  about: [
    'Enterprise AI transformation',
    'Data readiness for AI',
    'AI governance',
    'Workflow transformation',
    'Controlled autonomy',
    'Decision quality'
  ]
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.chandrakanojia.com' },
    { '@type': 'ListItem', position: 2, name: 'Enterprise AI Workbench', item: 'https://www.chandrakanojia.com/enterprise-ai-workbench' }
  ]
};
---
<PageLayout
  title="Enterprise AI Workbench | AI, Data, CRM and Workflow Readiness"
  description="A modular placeholder for an executive-safe AI demonstration focused on enterprise AI, data readiness, CRM, workflow, controls, and decision quality."
  canonical="https://www.chandrakanojia.com/enterprise-ai-workbench"
  ogImage="/images/og-workbench.png"
  jsonLd={[workbenchSchema, breadcrumbSchema]}
  noIndex={true}
>
  <section class="page-hero" aria-labelledby="workbench-title">
    <div class="container narrow">
      <p class="kicker">Enterprise AI Workbench</p>
      <h1 id="workbench-title">A separate AI demonstration module.</h1>
      <p class="lead">
        This page is intentionally modular. The core executive site is complete without it; the interactive AI demonstration can be developed, reviewed, and activated separately.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="module-title">
    <div class="container narrow">
      <div class="content-panel">
        <p class="kicker">Reserved module</p>
        <h2 id="module-title">The final Workbench should show AI turning messy enterprise context into a decision leaders can trust.</h2>
        <p class="body-large" style="margin-top:1rem;">
          The live version should demonstrate work, data, evidence, controls, human judgment, and decision quality without using confidential data or public visitor input.
        </p>
        <p class="body-large" style="margin-top:1rem;">
          Until that module is ready, this route is not indexed, not listed in the navigation, and not included in the sitemap.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="/enterprise-ai-transformation">Read the Enterprise AI point of view</a>
          <a class="button secondary" href="/insights">Read Field Notes</a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
