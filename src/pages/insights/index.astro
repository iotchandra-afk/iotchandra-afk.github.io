---
import PageLayout from '../../layouts/PageLayout.astro';

const webpageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://www.chandrakanojia.com/insights/#webpage',
  url: 'https://www.chandrakanojia.com/insights',
  name: 'Enterprise AI Field Notes | Chandra Kanojia',
  description: 'Field notes on enterprise AI, data readiness, CRM, workflow, evidence, controls, and regulated operating change.',
  isPartOf: { '@id': 'https://www.chandrakanojia.com/#website' },
  about: { '@id': 'https://www.chandrakanojia.com/#person' }
};

const insights = [
  {
    tag: 'Enterprise AI',
    title: 'AI Is Moving Faster Than the Enterprise.',
    href: '/insights/ai-moved-from-assistance-to-execution-operating-model-has-not',
    desc: 'The technology is moving quickly. The harder question is whether the enterprise can change work, governance, data, and decision-making fast enough to use it well.'
  },
  {
    tag: 'Data',
    title: 'The Data Problem Hiding Under Every AI Strategy.',
    href: '/insights/data-problem-hiding-under-every-ai-strategy',
    desc: 'Most AI plans talk about models. The harder question is whether trusted context reaches the workflow when a decision has to happen.'
  },
  {
    tag: 'Controlled autonomy',
    title: 'Controlled Autonomy Is the Enterprise AI Product.',
    href: '/insights/controlled-autonomy-is-the-enterprise-ai-product',
    desc: 'The useful agent is not the one that does the most. It is the one that acts within the right boundaries and hands the work back at the right moment.'
  },
  {
    tag: 'CRM',
    title: 'The CRM Trap: When Systems of Record Never Become Systems of Action.',
    href: '/insights/crm-trap-systems-of-record-never-become-systems-of-action',
    desc: 'CRM becomes valuable when it helps the enterprise decide what happens next. Recording activity is not enough.'
  }
];
---
<PageLayout
  title="Enterprise AI Field Notes | Work, Data, Controls and CRM"
  description="Field notes on enterprise AI, data readiness, CRM, workflow, evidence, controls, and regulated operating change."
  canonical="https://www.chandrakanojia.com/insights"
  ogImage="/images/og-field-notes.png"
  jsonLd={webpageSchema}
>
  <section class="page-hero" aria-labelledby="insights-title">
    <div class="container narrow">
      <p class="kicker">Field Notes</p>
      <h1 id="insights-title">What large enterprises learn after the AI demo.</h1>
      <p class="lead">The demo is the easy part. The harder question is what happens when AI enters real work: client conversations, advisor preparation, service workflows, CRM, case management, data handoffs, approvals, controls, exceptions, and leadership reporting.</p>
      <p class="body-large" style="margin-top:1rem;">These notes come from that gap — the space between AI capability and operating change.</p>
    </div>
  </section>

  <section class="section alt" aria-labelledby="seeing-title">
    <div class="container">
      <div class="section-heading compact-heading">
        <p class="kicker">What I keep seeing</p>
        <h2 id="seeing-title">Four truths keep showing up.</h2>
      </div>
      <div class="principles">
        <article class="principle"><p>Work has to change before AI matters.</p></article>
        <article class="principle"><p>Data has to be trusted before AI can act.</p></article>
        <article class="principle"><p>Autonomy needs boundaries.</p></article>
        <article class="principle"><p>The test is not the demo.</p></article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="notes-title">
    <div class="container">
      <div class="section-heading compact-heading">
        <p class="kicker">Selected notes</p>
        <h2 id="notes-title">One argument in four moves: work, data, autonomy, systems of action.</h2>
      </div>
      <div class="insight-grid four">
        {insights.map(item => (
          <article class="insight-card">
            <p class="tag">{item.tag}</p>
            <h3><a href={item.href}>{item.title}</a></h3>
            <p>{item.desc}</p>
          </article>
        ))}
      </div>
      <p class="insight-bridge">
        Together, these notes point to a larger leadership question: can the enterprise redesign work, data, decision-making, and controls fast enough to make AI matter without losing trust?
      </p>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="insights-cta">
    <div class="container">
      <div class="cta-box mandate-cta">
        <div>
          <p class="panel-label">Discuss the mandate</p>
          <h2 id="insights-cta">Useful conversations start when the question moves from “Can AI do this?” to “Can the enterprise change the work safely enough to make it matter?”</h2>
          <p>Relevant conversations include AI execution, data readiness, CRM and workflow modernization, operating leverage in regulated environments, platform reliability, adoption, governance, and executive confidence.</p>
        </div>
        <a class="button" href="https://www.linkedin.com/in/chandra-kanojia/" target="_blank" rel="noopener noreferrer">Connect on LinkedIn</a>
      </div>
    </div>
  </section>
</PageLayout>
