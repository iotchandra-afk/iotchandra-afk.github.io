---
// insights/index.astro
import PageLayout from '../../layouts/PageLayout.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://chandrakanojia.com" },
    { "@type": "ListItem", "position": 2, "name": "Insights", "item": "https://chandrakanojia.com/insights" }
  ]
};

const articles = [
  {
    slug: 'enterprise-ai-fails-when-operating-model-cannot-absorb-it',
    title: 'Enterprise AI Fails When the Operating Model Cannot Absorb It',
    pillar: 'Enterprise AI',
    date: '2025',
    lede: 'The dominant failure mode in enterprise AI is not technical. Organizations deploy capable models into operating environments not designed to absorb them — and wonder why the outcomes look like better reporting, not business change.',
  },
  {
    slug: 'crm-trap-systems-of-record-never-become-systems-of-action',
    title: 'The CRM Trap: When Systems of Record Never Become Systems of Action',
    pillar: 'CRM & Service',
    date: '2025',
    lede: 'CRM is the most consistently underperforming enterprise investment in financial services. The reason is not the platform. It is the operating model that was never redesigned to use it.',
  },
];
---

<PageLayout
  title="Insights | Chandra Kanojia"
  description="Chandra Kanojia's analysis and perspective on enterprise AI transformation, operating-model redesign, CRM modernization, and regulated-industry change. Original insight from an enterprise transformation operator."
  jsonLd={breadcrumbSchema}
>

  <!-- ═══ HEADER ═══ -->
  <section class="page-header" aria-labelledby="insights-main-heading">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb" role="list">
          <li><a href="/">Home</a></li>
          <li aria-hidden="true" style="color: var(--color-text-muted); margin: 0 0.5rem;">·</li>
          <li aria-current="page">Insights</li>
        </ol>
      </nav>
      <h1 class="page-title" id="insights-main-heading">Insights.</h1>
      <p class="page-lede">
        Analysis from an enterprise transformation operator. Original perspective on
        AI, operating models, CRM, and regulated-industry change — not theory.
      </p>
    </div>
  </section>

  <!-- ═══ ARTICLES ═══ -->
  <section class="section" aria-labelledby="articles-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-overline" aria-hidden="true">Published Analysis</p>
        <h2 class="section-title" id="articles-heading" class="sr-only">Articles</h2>
      </div>

      <div class="article-list" role="list">
        {articles.map((article, i) => (
          <article class="article-row" role="listitem">
            <a href={`/insights/${article.slug}`} class="article-row-link" aria-label={`Read: ${article.title}`}>
              <div class="article-row-meta">
                <span class="insight-pillar">{article.pillar}</span>
                <span class="insight-date">{article.date}</span>
              </div>
              <div class="article-row-content">
                <h3>{article.title}</h3>
                <p>{article.lede}</p>
              </div>
              <span class="article-row-arrow" aria-hidden="true">Read →</span>
            </a>
          </article>
        ))}
      </div>

      <div class="divider-text" aria-hidden="true">More essays forthcoming</div>

      <div class="prose">
        <p>
          New analysis published as operating observations warrant it.
          Chandra writes on enterprise AI transformation, operating-model design,
          CRM and service transformation, and regulated-industry change.
          No publishing cadence for its own sake. No commodity content.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ NEWSLETTER PLACEHOLDER ═══ -->
  <section class="section section--surface" aria-labelledby="signal-heading">
    <div class="container">
      <div class="om-grid">
        <div class="om-label" aria-hidden="true">Signal</div>
        <div class="om-content">
          <h2 class="section-title" id="signal-heading">Stay current with new analysis.</h2>
          <p class="section-body">
            New essays are shared directly via LinkedIn. Connect to receive
            new analysis as it is published.
          </p>
          <div style="margin-top: var(--space-8);">
            <a
              href="https://www.linkedin.com/in/chandra-kanojia/"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn--primary"
              aria-label="Follow Chandra Kanojia on LinkedIn (opens in new tab)"
            >
              Follow on LinkedIn ↗
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</PageLayout>

<style>
.breadcrumb {
  display: flex; align-items: center; list-style: none;
  padding: 0; margin: 0 0 var(--space-8);
  font-family: var(--font-mono); font-size: var(--text-mono);
  letter-spacing: var(--ls-wide); color: var(--color-text-muted);
}
.breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
.breadcrumb a:hover { color: var(--color-text-primary); }

.article-list {
  display: flex;
  flex-direction: column;
  gap: 1px;
  background: var(--color-hairline);
  border: var(--border-thin);
}

.article-row {
  background: var(--color-elevated);
}

.article-row-link {
  display: grid;
  grid-template-columns: 1fr auto;
  grid-template-rows: auto auto;
  gap: var(--space-4) var(--space-8);
  padding: var(--space-8);
  text-decoration: none;
  transition: background var(--transition-fast);
}
.article-row-link:hover {
  background: var(--color-surface);
  text-decoration: none;
}

.article-row-meta {
  grid-column: 1 / 2;
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

.article-row-content {
  grid-column: 1 / 2;
}

.article-row-content h3 {
  font-size: 1.125rem;
  font-weight: 500;
  letter-spacing: var(--ls-heading);
  line-height: 1.35;
  color: var(--color-text-primary);
  margin-bottom: var(--space-3);
}

.article-row-content p {
  font-size: var(--text-small);
  line-height: var(--lh-body);
  color: var(--color-text-muted);
  max-width: 680px;
}

.article-row-arrow {
  grid-column: 2 / 3;
  grid-row: 1 / 3;
  align-self: center;
  font-family: var(--font-mono);
  font-size: var(--text-mono);
  letter-spacing: var(--ls-wider);
  text-transform: uppercase;
  color: var(--color-text-muted);
  white-space: nowrap;
  transition: color var(--transition-fast), transform var(--transition-fast);
}
.article-row-link:hover .article-row-arrow {
  color: var(--color-text-primary);
  transform: translateX(3px);
}

@media (max-width: 640px) {
  .article-row-link {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto auto;
  }
  .article-row-arrow {
    grid-column: 1;
    grid-row: auto;
  }
}
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  border: 0;
}
</style>
