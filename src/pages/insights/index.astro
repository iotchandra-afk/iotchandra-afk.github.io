---
import PageLayout from '../../layouts/PageLayout.astro';

const webpageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://chandrakanojia.com/insights/#webpage',
  url: 'https://chandrakanojia.com/insights',
  name: 'Insights | Chandra Kanojia',
  description: 'Field notes on enterprise AI, CRM, workflow, and regulated operating change.',
  isPartOf: { '@id': 'https://chandrakanojia.com/#website' },
  about: { '@id': 'https://chandrakanojia.com/#person' }
};

const insights = [
  {
    tag: 'Enterprise AI',
    title: 'AI Has Moved From Assistance to Execution. The Operating Model Has Not.',
    href: '/insights/ai-moved-from-assistance-to-execution-operating-model-has-not',
    desc: 'A board-level operating note on controlled autonomy, evidence discipline, and workflow ownership.'
  },
  {
    tag: 'Controlled autonomy',
    title: 'Controlled Autonomy Is the Enterprise AI Product.',
    href: '/insights/controlled-autonomy-is-the-enterprise-ai-product',
    desc: 'Why production AI needs routing, retrieval, validation, escalation, auditability, and clear permission boundaries.'
  },
  {
    tag: 'CRM',
    title: 'The CRM Trap: When Systems of Record Never Become Systems of Action.',
    href: '/insights/crm-trap-systems-of-record-never-become-systems-of-action',
    desc: 'CRM only creates value when it changes how work moves, decisions get made, and outcomes are governed.'
  }
];
---
<PageLayout
  title="Insights | Chandra Kanojia"
  description="Field notes on enterprise AI, CRM, workflow, and regulated operating change."
  canonical="https://chandrakanojia.com/insights"
  jsonLd={webpageSchema}
>
  <section class="page-hero" aria-labelledby="insights-title">
    <div class="container narrow">
      <p class="kicker">Insights</p>
      <h1 id="insights-title">Field notes for the execution phase of enterprise AI.</h1>
      <p class="lead">Short operating notes on AI execution, CRM/workflow systems, regulated change, and the work required after the demo.</p>
    </div>
  </section>

  <section class="section" aria-label="Insight articles">
    <div class="container">
      <div class="insight-grid three">
        {insights.map(item => (
          <article class="insight-card">
            <p class="tag">{item.tag}</p>
            <h3><a href={item.href}>{item.title}</a></h3>
            <p>{item.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
