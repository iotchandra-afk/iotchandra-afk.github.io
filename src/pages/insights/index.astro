---
import PageLayout from '../../layouts/PageLayout.astro';

const webpageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": "https://chandrakanojia.com/insights/#webpage",
  "url": "https://chandrakanojia.com/insights",
  "name": "Insights | Chandra Kanojia",
  "description": "Field notes on enterprise AI, CRM, workflow, and regulated operating change.",
  "isPartOf": { "@id": "https://chandrakanojia.com/#website" },
  "about": { "@id": "https://chandrakanojia.com/#person" }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://chandrakanojia.com" },
    { "@type": "ListItem", "position": 2, "name": "Insights", "item": "https://chandrakanojia.com/insights" }
  ]
};

const posts = [
  {
    title: "AI Has Moved From Assistance to Execution. The Operating Model Has Not.",
    tag: "Enterprise AI",
    href: "/insights/ai-moved-from-assistance-to-execution-operating-model-has-not",
    summary: "A board-level operating note on controlled autonomy, evidence discipline, and workflow ownership."
  },
  {
    title: "Enterprise AI Fails When the Operating Model Cannot Absorb It.",
    tag: "Operating Model",
    href: "/insights/enterprise-ai-fails-when-operating-model-cannot-absorb-it",
    summary: "Why governance, adoption, and execution discipline matter more than a larger pilot portfolio."
  },
  {
    title: "The CRM Trap: When Systems of Record Never Become Systems of Action.",
    tag: "CRM",
    href: "/insights/crm-trap-systems-of-record-never-become-systems-of-action",
    summary: "CRM transformation fails when workflow, data, decision rights, and adoption stay outside the operating design."
  }
];
---

<PageLayout
  title="AI Insights for Regulated Enterprise Transformation | Chandra Kanojia"
  description="Field notes on enterprise AI, CRM, workflow, and regulated operating change."
  canonical="https://chandrakanojia.com/insights"
  jsonLd={[webpageSchema, breadcrumbSchema]}
>
  <section class="page-hero" aria-labelledby="insights-title">
    <div class="container narrow">
      <p class="eyebrow">Insights</p>
      <h1 id="insights-title">Field notes on enterprise AI, CRM, workflow, and regulated operating change.</h1>
    </div>
  </section>

  <section class="section" aria-label="Insight articles">
    <div class="container">
      <div class="card-grid three">
        {posts.map(post => (
          <article class="insight-card">
            <p class="card-kicker">{post.tag}</p>
            <h2><a href={post.href}>{post.title}</a></h2>
            <p>{post.summary}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section small" aria-labelledby="insights-cta-title">
    <div class="container narrow">
      <h2 id="insights-cta-title">Selected commentary will remain curated.</h2>
      <p>LinkedIn commentary can be linked selectively later without turning this site into a live feed.</p>
      <a class="button secondary" href="https://www.linkedin.com/in/chandra-kanojia/" target="_blank" rel="noopener noreferrer">View LinkedIn</a>
    </div>
  </section>
</PageLayout>
