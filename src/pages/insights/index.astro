---
import PageLayout from '../../layouts/PageLayout.astro';

const webpageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://chandrakanojia.com/insights/#webpage',
  url: 'https://chandrakanojia.com/insights',
  name: 'Field Notes | Chandra Kanojia',
  description: 'Field notes on enterprise AI, CRM, workflow, evidence, controls, and regulated operating change.',
  isPartOf: { '@id': 'https://chandrakanojia.com/#website' },
  about: { '@id': 'https://chandrakanojia.com/#person' }
};

const insights = [
  {
    tag: 'Enterprise AI',
    title: 'AI Is Moving Faster Than the Enterprise.',
    href: '/insights/ai-moved-from-assistance-to-execution-operating-model-has-not',
    desc: 'The technology is advancing quickly. The harder question is whether the enterprise can change work, governance, and decision-making fast enough to use it well.'
  },
  {
    tag: 'Controlled autonomy',
    title: 'Controlled Autonomy Is the Enterprise AI Product.',
    href: '/insights/controlled-autonomy-is-the-enterprise-ai-product',
    desc: 'The useful agent is not the one that does the most. It is the one that acts within the right boundaries and hands the work back at the right moment.'
  },
  {
    tag: 'CRM',
    title: 'The CRM Trap: When Systems of Record Never Become Systems of Action.',
    href: '/insights/crm-trap-systems-of-record-never-become-systems-of-action',
    desc: 'CRM becomes valuable when it helps the enterprise decide what happens next. Recording activity is not enough.'
  }
];
---
<PageLayout
  title="Field Notes | Chandra Kanojia"
  description="Field notes on enterprise AI, CRM, workflow, evidence, controls, and regulated operating change."
  canonical="https://chandrakanojia.com/insights"
  jsonLd={webpageSchema}
>
  <section class="page-hero" aria-labelledby="insights-title">
    <div class="container narrow">
      <p class="kicker">Field Notes</p>
      <h1 id="insights-title">What large enterprises learn after the AI demo.</h1>
      <p class="lead">The demo is the easy part. The harder question is what happens when AI enters real work: client conversations, advisor preparation, service workflows, CRM, case management, approvals, controls, exceptions, and leadership reporting.</p>
      <p class="body-large" style="margin-top:1rem;">These notes come from that gap — the space between AI capability and operating change.</p>
    </div>
  </section>

  <section class="section alt" aria-labelledby="seeing-title">
    <div class="container">
      <div class="section-heading compact-heading">
        <p class="kicker">What I keep seeing</p>
        <h2 id="seeing-title">The work has to change before AI matters.</h2>
      </div>
      <div class="principles">
        <article class="principle"><p>A better tool does not automatically create a better business process.</p></article>
        <article class="principle"><p>A fluent answer is not a reliable decision. Leaders need to know what was used, what was missed, and what would change the conclusion.</p></article>
        <article class="principle"><p>Useful AI acts where the permissions, controls, audit path, and human escalation are clear.</p></article>
        <article class="principle"><p>The test is cycle time, capacity, experience, risk, and revenue velocity.</p></article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="notes-title">
    <div class="container">
      <div class="section-heading compact-heading">
        <p class="kicker">Selected notes</p>
        <h2 id="notes-title">One argument in three moves.</h2>
      </div>
      <div class="insight-grid three">
        {insights.map(item => (
          <article class="insight-card">
            <p class="tag">{item.tag}</p>
            <h3><a href={item.href}>{item.title}</a></h3>
            <p>{item.desc}</p>
          </article>
        ))}
      </div>
      <p class="insight-bridge">
        Together, these are not separate technology topics. They point to a larger leadership mandate: how enterprises redesign work, decision-making, and operating models for an AI-driven economy.
      </p>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="insights-cta">
    <div class="container">
      <div class="cta-box mandate-cta">
        <div>
          <p class="panel-label">Discuss the mandate</p>
          <h2 id="insights-cta">Useful conversations start when the question moves from “Can AI do this?” to “Can the enterprise change the work safely enough to make it matter?”</h2>
          <p>Relevant conversations include AI execution, CRM and workflow modernization, operating leverage in regulated environments, platform reliability, adoption, governance, and executive confidence.</p>
        </div>
        <a class="button" href="https://www.linkedin.com/in/chandra-kanojia/" target="_blank" rel="noopener noreferrer">Connect on LinkedIn</a>
      </div>
    </div>
  </section>
</PageLayout>
