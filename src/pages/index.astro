---
import PageLayout from '../layouts/PageLayout.astro';

const webpageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://chandrakanojia.com/#webpage",
  "url": "https://chandrakanojia.com",
  "name": "Enterprise AI Transformation | Chandra Kanojia",
  "description": "Chandra Kanojia helps large regulated enterprises turn AI, CRM/Salesforce, workflow, analytics, and platform investment into governed operating outcomes.",
  "isPartOf": { "@id": "https://chandrakanojia.com/#website" },
  "about": { "@id": "https://chandrakanojia.com/#person" }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://chandrakanojia.com" }
  ]
};

const metrics = [
  ["7.2M+", "service cases managed"],
  ["99.5%", "platform availability"],
  ["$112M", "process-savings contribution"],
  ["$500M+", "transformation-program scale"],
  ["37%", "year-over-year growth supported"],
  ["$10M–$300M", "pull-through deal influence"],
  ["$15M–$20M", "delivery portfolio managed"],
  ["$8M–$12M", "advisory revenue generated"]
];
---

<PageLayout
  title="Enterprise AI Transformation | Chandra Kanojia"
  description="Chandra Kanojia helps large regulated enterprises turn AI, CRM/Salesforce, workflow, analytics, and platform investment into governed operating outcomes."
  jsonLd={[webpageSchema, breadcrumbSchema]}
>
  <section class="hero compact-hero" aria-labelledby="hero-title">
    <div class="container narrow">
      <p class="eyebrow">Enterprise AI · CRM/Salesforce · Workflow · Regulated Transformation</p>
      <h1 id="hero-title">Enterprise AI That Changes How Regulated Work Gets Done.</h1>
      <p class="hero-copy">
        Chandra Kanojia helps large regulated enterprises turn AI, CRM/Salesforce, workflow, analytics, and platform investment into governed operating outcomes.
      </p>
      <p class="hero-note">
        The work sits where transformation usually breaks: workflow design, adoption, platform reliability, decision rights, controls, and measurable business value.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/executive-profile">View Executive Profile</a>
        <a class="button secondary" href="/enterprise-ai-transformation">Read Enterprise AI View</a>
      </div>
    </div>
  </section>

  <section class="metric-section" aria-label="Operating proof">
    <div class="container">
      <div class="metric-grid">
        {metrics.map(([value, label]) => (
          <div class="metric-card">
            <strong>{value}</strong>
            <span>{label}</span>
          </div>
        ))}
      </div>
      <p class="experience-line">Experience across Fidelity Investments, Accenture, Cognizant, Virtusa, Fortune 100 financial services, and global delivery environments.</p>
    </div>
  </section>

  <section class="section" aria-labelledby="lanes-title">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Where the work lands</p>
        <h2 id="lanes-title">Three deployment lanes.</h2>
      </div>
      <div class="card-grid three">
        <article class="card">
          <h3>Enterprise AI execution</h3>
          <p>Moving AI from pilots and demos into governed workflow patterns that business leaders can fund, adopt, and scale.</p>
        </article>
        <article class="card">
          <h3>CRM, workflow, and enterprise applications</h3>
          <p>Turning CRM, case management, analytics, advisor platforms, and workflow systems into operating leverage.</p>
        </article>
        <article class="card">
          <h3>Regulated transformation</h3>
          <p>Building change inside financial-services, insurance, retirement, brokerage, healthcare, risk, compliance, and control realities.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section muted" aria-labelledby="insights-title">
    <div class="container">
      <div class="section-heading split">
        <div>
          <p class="eyebrow">Selected insights</p>
          <h2 id="insights-title">Field notes on enterprise AI, CRM, workflow, and regulated operating change.</h2>
        </div>
        <a class="text-link" href="/insights">View all insights</a>
      </div>
      <div class="card-grid two">
        <article class="insight-card">
          <p class="card-kicker">Enterprise AI</p>
          <h3><a href="/insights/ai-moved-from-assistance-to-execution-operating-model-has-not">AI Has Moved From Assistance to Execution. The Operating Model Has Not.</a></h3>
          <p>A board-level operating note on controlled autonomy, evidence discipline, and workflow ownership.</p>
        </article>
        <article class="insight-card">
          <p class="card-kicker">CRM</p>
          <h3><a href="/insights/crm-trap-systems-of-record-never-become-systems-of-action">The CRM Trap: When Systems of Record Never Become Systems of Action.</a></h3>
          <p>Why CRM transformation fails when workflow, data, decision rights, and adoption stay outside the operating design.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="cta-title">
    <div class="container narrow">
      <h2 id="cta-title">For board, CXO, executive search, consulting, and enterprise AI conversations.</h2>
      <a class="button primary" href="https://www.linkedin.com/in/chandra-kanojia/" target="_blank" rel="noopener noreferrer">Connect on LinkedIn</a>
    </div>
  </section>
</PageLayout>
