---
// index.astro — Home page
import PageLayout from '../layouts/PageLayout.astro';

const webpageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://chandrakanojia.com/#webpage",
  "url": "https://chandrakanojia.com",
  "name": "Enterprise AI Transformation Leader | Regulated Operating Outcomes | Chandra Kanojia",
  "description": "Chandra Kanojia helps large regulated enterprises convert AI, CRM/Salesforce, workflow, analytics, and platform investment into governed operating outcomes — where transformation usually breaks: workflow redesign, adoption, platform reliability, decision rights, and measurable business value.",
  "isPartOf": { "@id": "https://chandrakanojia.com/#website" },
  "about": { "@id": "https://chandrakanojia.com/#person" }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://chandrakanojia.com" }
  ]
};
---

<PageLayout
  title="Enterprise AI Transformation Leader | Regulated Operating Outcomes | Chandra Kanojia"
  description="Chandra Kanojia helps large regulated enterprises convert AI, CRM/Salesforce, workflow, analytics, and platform investment into governed operating outcomes — where transformation usually breaks: workflow redesign, adoption, platform reliability, decision rights, and measurable business value."
  jsonLd={[webpageSchema, breadcrumbSchema]}
>

  <!-- ═══ HERO ═══ -->
  <section class="hero" aria-labelledby="hero-headline">
    <div class="container">
      <p class="hero-eyebrow" aria-hidden="true">Enterprise AI · CRM · Workflow · Regulated Financial Services</p>
      <h1 class="hero-headline" id="hero-headline">
        Enterprise AI That Becomes<br/>Operating Leverage.
      </h1>
      <p class="hero-subheadline">
        Chandra Kanojia helps large regulated enterprises convert AI, CRM,
        Salesforce, workflow, analytics, and platform investment into governed
        operating outcomes. The work sits where transformation usually breaks:
        workflow redesign, adoption, platform reliability, decision rights,
        controls, and measurable business value.
      </p>
      <div class="hero-actions">
        <a href="/executive-profile" class="btn btn--primary">View Executive Profile</a>
        <a href="/enterprise-ai-transformation" class="btn btn--ghost">The Operating Thesis →</a>
      </div>
    </div>
  </section>

  <!-- ═══ INSTITUTION BAND ═══ -->
  <section class="proof-band" aria-label="Institutional experience">
    <div class="container">
      <div class="proof-band-inner">
        <span class="proof-label">Experience across</span>
        <div class="proof-items" role="list">
          <span class="proof-item" role="listitem">Fidelity Investments</span>
          <span class="proof-item" role="listitem">Accenture</span>
          <span class="proof-item" role="listitem">Cognizant</span>
          <span class="proof-item" role="listitem">Virtusa</span>
          <span class="proof-item" role="listitem">Fortune 100 Financial Services</span>
          <span class="proof-item" role="listitem">US · UK · Germany · South Asia</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ METRIC BAND ═══ -->
  <section class="metric-band" aria-label="Operating proof points">
    <div class="container">
      <div class="metric-band-inner" role="list">
        <div class="metric-cell" role="listitem">
          <span class="metric-value">7.2M+</span>
          <span class="metric-label">Service cases managed on platform</span>
        </div>
        <div class="metric-cell" role="listitem">
          <span class="metric-value">99.5%</span>
          <span class="metric-label">Platform availability sustained</span>
        </div>
        <div class="metric-cell" role="listitem">
          <span class="metric-value">$112M</span>
          <span class="metric-label">Process-savings contribution</span>
        </div>
        <div class="metric-cell" role="listitem">
          <span class="metric-value">$500M+</span>
          <span class="metric-label">Transformation-program scale</span>
        </div>
        <div class="metric-cell" role="listitem">
          <span class="metric-value">37%</span>
          <span class="metric-label">Year-over-year growth supported</span>
        </div>
        <div class="metric-cell" role="listitem">
          <span class="metric-value">$10M–$300M</span>
          <span class="metric-label">Pull-through deal influence</span>
        </div>
        <div class="metric-cell" role="listitem">
          <span class="metric-value">$15M–$20M</span>
          <span class="metric-label">Delivery portfolio managed</span>
        </div>
        <div class="metric-cell" role="listitem">
          <span class="metric-value">$8M–$12M</span>
          <span class="metric-label">Advisory revenue generated</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ OPERATING THESIS ═══ -->
  <section class="section" aria-labelledby="thesis-heading">
    <div class="container">
      <div class="om-section">
        <div class="om-grid">
          <div class="om-label" aria-hidden="true">Thesis</div>
          <div class="om-content">
            <div class="section-header">
              <p class="section-overline" aria-hidden="true">The Operating Thesis</p>
              <h2 class="section-title" id="thesis-heading">
                Transformation only counts when it lasts.
              </h2>
              <p class="section-body">
                Most enterprise AI programs fail not because the technology is wrong,
                but because the operating model was never designed to absorb it.
                Real transformation requires three things built together: governance
                that decides fast, adoption that changes behavior at scale, and
                execution discipline that converts strategy into measurable outcomes.
              </p>
            </div>

            <div class="pull-quote-block" role="blockquote">
              <p class="pull-quote-text">
                The next enterprise AI advantage will not come from better demos.
                It will come from operating models that can absorb AI, govern it,
                and turn it into measurable work.
              </p>
            </div>

            <a href="/enterprise-ai-transformation" class="btn btn--text">
              Read the full operating thesis
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="section-rule" style="margin: 0;" aria-hidden="true"/>

  <!-- ═══ OPERATING DOMAINS ═══ -->
  <section class="section" aria-labelledby="themes-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-overline" aria-hidden="true">Operating Domains</p>
        <h2 class="section-title" id="themes-heading">
          CRM, AI, workflow, analytics, and platform — where the work lands.
        </h2>
      </div>

      <div class="theme-grid" role="list">
        <article class="theme-cell" role="listitem">
          <p class="theme-cell-label" aria-hidden="true">01</p>
          <h3>Enterprise AI Operating Models</h3>
          <p>Moving AI from pilots and demos into governed workflow patterns that business leaders can fund, adopt, and reuse.</p>
        </article>

        <article class="theme-cell" role="listitem">
          <p class="theme-cell-label" aria-hidden="true">02</p>
          <h3>CRM & Salesforce Modernization</h3>
          <p>Converting CRM from a system of record into a system of action for advisors, associates, service teams, and relationship leaders.</p>
        </article>

        <article class="theme-cell" role="listitem">
          <p class="theme-cell-label" aria-hidden="true">03</p>
          <h3>Workflow & Enterprise Application Transformation</h3>
          <p>Improving how work moves across case management, analytics, service operations, advisor platforms, and large enterprise applications.</p>
        </article>

        <article class="theme-cell" role="listitem">
          <p class="theme-cell-label" aria-hidden="true">04</p>
          <h3>Regulated-Enterprise Transformation</h3>
          <p>Building change inside financial services, insurance, retirement, brokerage, healthcare, and compliance realities — where constraints are design inputs.</p>
        </article>

        <article class="theme-cell" role="listitem">
          <p class="theme-cell-label" aria-hidden="true">05</p>
          <h3>Governance, Adoption & Execution</h3>
          <p>Accountability structures that convert large transformation programs into measurable, durable operating outcomes.</p>
        </article>

        <article class="theme-cell" role="listitem">
          <p class="theme-cell-label" aria-hidden="true">06</p>
          <h3>Cost-to-Serve & Platform Reliability</h3>
          <p>Reducing operating friction, improving service quality, and sustaining platform performance at enterprise scale.</p>
        </article>
      </div>

      <div style="margin-top: var(--space-10);">
        <a href="/executive-profile" class="btn btn--ghost">View full profile →</a>
      </div>
    </div>
  </section>

  <!-- ═══ PROOF VIGNETTES ═══ -->
  <section class="section section--surface" aria-labelledby="proof-heading">
    <div class="container">
      <div class="om-grid">
        <div class="om-label" aria-hidden="true">Proof</div>
        <div class="om-content">
          <div class="section-header">
            <p class="section-overline" aria-hidden="true">Operating Record</p>
            <h2 class="section-title" id="proof-heading">
              Selected outcomes from the record.
            </h2>
          </div>

          <div class="proof-vignettes">
            <article class="proof-vignette">
              <p class="proof-vignette-tag" aria-hidden="true">CRM & Platform</p>
              <h3>Salesforce CRM at Enterprise Scale</h3>
              <p>Led CRM and service-platform modernization across a large regulated financial services environment — 7.2M+ cases managed, 99.5% platform availability, governance and workflow redesign that converted platform investment into operating performance.</p>
            </article>

            <article class="proof-vignette">
              <p class="proof-vignette-tag" aria-hidden="true">Commercial Outcomes</p>
              <h3>AI-Enabled Relationship Intelligence</h3>
              <p>Designed and deployed an AI-enabled relationship intelligence model contributing to 37% year-over-year growth in targeted segments and measurable commercial outcomes inside a regulated wealth management environment.</p>
            </article>

            <article class="proof-vignette">
              <p class="proof-vignette-tag" aria-hidden="true">Process Economics</p>
              <h3>$112M Process-Savings Contribution</h3>
              <p>Workflow transformation and cost-to-serve programs that reduced operating friction, improved associate and advisor productivity, and contributed $112M in process-savings across regulated financial services operations.</p>
            </article>

            <article class="proof-vignette">
              <p class="proof-vignette-tag" aria-hidden="true">Delivery Scale</p>
              <h3>$500M+ Transformation at Global Scale</h3>
              <p>Led cross-functional transformation programs across the US, UK, Germany, and South Asia — managing $500M+ in transformation-program scale with consistent governance and operating architecture.</p>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURED INSIGHTS ═══ -->
  <section class="section" aria-labelledby="insights-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-overline" aria-hidden="true">Insights</p>
        <h2 class="section-title" id="insights-heading">
          Analysis from fifteen years inside enterprise transformation.
        </h2>
      </div>

      <div class="insights-grid">
        <a href="/insights/ai-moved-from-assistance-to-execution-operating-model-has-not" class="insight-card" aria-label="Read: AI Has Moved From Assistance to Execution. The Operating Model Has Not.">
          <div class="insight-card-meta">
            <span class="insight-pillar">Enterprise AI</span>
            <span class="insight-date">2025</span>
          </div>
          <h3>AI Has Moved From Assistance to Execution. The Operating Model Has Not.</h3>
          <p>Deploying copilots is not the same as redesigning work. The enterprise AI question is no longer whether the technology can produce capability — it is whether management can govern the investment and convert it into measurable operating advantage.</p>
          <span class="insight-card-arrow" aria-hidden="true">Read →</span>
        </a>

        <a href="/insights/enterprise-ai-fails-when-operating-model-cannot-absorb-it" class="insight-card" aria-label="Read: Enterprise AI Fails When the Operating Model Cannot Absorb It">
          <div class="insight-card-meta">
            <span class="insight-pillar">Operating Models</span>
            <span class="insight-date">2025</span>
          </div>
          <h3>Enterprise AI Fails When the Operating Model Cannot Absorb It</h3>
          <p>The dominant failure mode in enterprise AI is not technical. Organizations deploy capable models into operating environments not designed to absorb them — and wonder why the outcomes look like better reporting, not business change.</p>
          <span class="insight-card-arrow" aria-hidden="true">Read →</span>
        </a>
      </div>

      <div style="margin-top: var(--space-10);">
        <a href="/insights" class="btn btn--ghost">View all insights →</a>
      </div>
    </div>
  </section>

  <!-- ═══ CONTACT CTA ═══ -->
  <section class="section section--surface" aria-labelledby="cta-heading">
    <div class="container">
      <div class="two-col">
        <div>
          <p class="section-overline" aria-hidden="true">Connect</p>
          <h2 class="section-title" id="cta-heading">
            Board conversations, CXO mandates, and executive search.
          </h2>
          <p class="section-body">
            For boards, CXO hiring leaders, executive search partners, consulting firms,
            and enterprise AI companies: connect directly on LinkedIn.
          </p>
          <div class="hero-actions" style="margin-top: var(--space-8);">
            <a href="/contact" class="btn btn--primary">Connect on LinkedIn</a>
            <a href="/executive-profile" class="btn btn--ghost">View Executive Profile</a>
          </div>
        </div>

        <div class="stack stack--sm" style="padding-top: var(--space-4);">
          <div class="credentials-list">
            <div class="credential-item">
              <span class="cred-org">IIM Bangalore</span>
              <span class="cred-prog">MBA</span>
            </div>
            <div class="credential-item">
              <span class="cred-org">Carnegie Mellon University</span>
              <span class="cred-prog">CIO Program</span>
            </div>
            <div class="credential-item">
              <span class="cred-org">NIT Allahabad</span>
              <span class="cred-prog">B.Tech</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</PageLayout>
