---
import PageLayout from '../layouts/PageLayout.astro';

const webpageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://chandrakanojia.com/#webpage",
  "url": "https://chandrakanojia.com",
  "name": "Enterprise AI That Becomes Operating Leverage | Chandra Kanojia",
  "description": "Chandra Kanojia helps large regulated enterprises convert AI, CRM/Salesforce, workflow, analytics, and platform investment into governed operating outcomes.",
  "isPartOf": { "@id": "https://chandrakanojia.com/#website" },
  "about": { "@id": "https://chandrakanojia.com/#person" }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://chandrakanojia.com" }
  ]
};
---

<PageLayout
  title="Enterprise AI That Becomes Operating Leverage | Chandra Kanojia"
  description="Chandra Kanojia helps large regulated enterprises convert AI, CRM/Salesforce, workflow, analytics, and platform investment into governed operating outcomes."
  jsonLd={[webpageSchema, breadcrumbSchema]}
>
  <section class="hero" aria-labelledby="hero-headline">
    <div class="container">
      <p class="hero-eyebrow" aria-hidden="true">Enterprise AI · CRM/Salesforce · Workflow · Regulated Operating Change</p>
      <h1 class="hero-headline" id="hero-headline">Enterprise AI That Becomes<br />Operating Leverage.</h1>
      <p class="hero-subheadline">
        Chandra Kanojia helps large regulated enterprises convert AI, CRM/Salesforce,
        workflow, analytics, and platform investment into governed operating outcomes.
        The work sits where transformation usually breaks: workflow redesign, adoption,
        platform reliability, decision rights, controls, and measurable business value.
      </p>
      <div class="hero-actions">
        <a href="/executive-profile" class="btn btn--primary">View Executive Profile</a>
        <a href="/enterprise-ai-transformation" class="btn btn--ghost">Enterprise AI Perspective</a>
      </div>
    </div>
  </section>

  <section class="metric-band" aria-label="Operating proof">
    <div class="container">
      <div class="metric-band-inner" role="list">
        <div class="metric-cell" role="listitem"><span class="metric-value">7.2M+</span><span class="metric-label">Service cases managed</span></div>
        <div class="metric-cell" role="listitem"><span class="metric-value">37%</span><span class="metric-label">Year-over-year growth supported</span></div>
        <div class="metric-cell" role="listitem"><span class="metric-value">99.5%</span><span class="metric-label">Platform availability</span></div>
        <div class="metric-cell" role="listitem"><span class="metric-value">$15M–$20M</span><span class="metric-label">Delivery portfolio</span></div>
        <div class="metric-cell" role="listitem"><span class="metric-value">$500M+</span><span class="metric-label">Transformation-program scale</span></div>
        <div class="metric-cell" role="listitem"><span class="metric-value">$112M</span><span class="metric-label">Process-savings contribution</span></div>
        <div class="metric-cell" role="listitem"><span class="metric-value">$8M–$12M</span><span class="metric-label">Advisory revenue generated</span></div>
        <div class="metric-cell" role="listitem"><span class="metric-value">$10M–$300M</span><span class="metric-label">Pull-through deal influence</span></div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="lanes-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-overline" aria-hidden="true">Where the work lands</p>
        <h2 class="section-title" id="lanes-heading">Three lanes where AI becomes operating leverage.</h2>
      </div>
      <div class="theme-grid theme-grid--three" role="list">
        <article class="theme-cell" role="listitem">
          <h3>Enterprise AI execution</h3>
          <p>Moving AI from pilots and demos into governed workflow patterns that business leaders can fund, adopt, and scale.</p>
        </article>
        <article class="theme-cell" role="listitem">
          <h3>CRM, workflow, and enterprise applications</h3>
          <p>Turning CRM, case management, analytics, advisor platforms, and workflow systems into operating leverage.</p>
        </article>
        <article class="theme-cell" role="listitem">
          <h3>Regulated transformation</h3>
          <p>Building change inside financial-services, insurance, retirement, brokerage, healthcare, risk, compliance, and control realities.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--surface" aria-labelledby="quote-heading">
    <div class="container">
      <div class="pull-quote-block" role="blockquote" aria-labelledby="quote-heading">
        <h2 id="quote-heading" class="sr-only">Enterprise AI point of view</h2>
        <p class="pull-quote-text">
          The next enterprise AI advantage will not come from better demos. It will come from operating models that can absorb AI, govern it, and turn it into measurable work.
        </p>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="insights-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-overline" aria-hidden="true">Insights</p>
        <h2 class="section-title" id="insights-heading">Field notes on enterprise AI, CRM, workflow, and regulated operating change.</h2>
      </div>
      <div class="insights-grid">
        <a href="/insights/ai-moved-from-assistance-to-execution-operating-model-has-not" class="insight-card" aria-label="Read: AI Has Moved From Assistance to Execution. The Operating Model Has Not.">
          <div class="insight-card-meta"><span class="insight-pillar">Enterprise AI</span><span class="insight-date">2025</span></div>
          <h3>AI Has Moved From Assistance to Execution. The Operating Model Has Not.</h3>
          <p>Deploying copilots is not the same as redesigning work. The harder problem is governed execution inside real enterprise systems.</p>
          <span class="insight-card-arrow" aria-hidden="true">Read →</span>
        </a>
        <a href="/insights/crm-trap-systems-of-record-never-become-systems-of-action" class="insight-card" aria-label="Read: The CRM Trap">
          <div class="insight-card-meta"><span class="insight-pillar">CRM</span><span class="insight-date">2025</span></div>
          <h3>The CRM Trap: When Systems of Record Never Become Systems of Action.</h3>
          <p>CRM value shows up when relationship context, workflow, analytics, and execution discipline change how work moves.</p>
          <span class="insight-card-arrow" aria-hidden="true">Read →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--surface" aria-labelledby="cta-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-overline" aria-hidden="true">Connect</p>
        <h2 class="section-title" id="cta-heading">For board, CXO, executive search, consulting, and enterprise AI conversations.</h2>
        <p class="section-body">Connect directly on LinkedIn for the right mandate.</p>
      </div>
      <div class="hero-actions">
        <a href="/contact" class="btn btn--primary">Connect on LinkedIn</a>
        <a href="/executive-profile" class="btn btn--ghost">View Executive Profile</a>
      </div>
    </div>
  </section>
</PageLayout>
