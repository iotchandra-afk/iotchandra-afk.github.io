---
import PageLayout from '../layouts/PageLayout.astro';

const webpageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://chandrakanojia.com/#webpage',
  url: 'https://chandrakanojia.com',
  name: 'Enterprise AI Under Control | Chandra Kanojia',
  description: 'Chandra Kanojia helps large regulated enterprises turn AI, CRM/Salesforce, workflow, analytics, and platform investment into governed operating outcomes.',
  isPartOf: { '@id': 'https://chandrakanojia.com/#website' },
  about: { '@id': 'https://chandrakanojia.com/#person' }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://chandrakanojia.com' }
  ]
};
---
<PageLayout
  title="Enterprise AI Under Control | Chandra Kanojia"
  description="Chandra Kanojia helps large regulated enterprises turn AI, CRM/Salesforce, workflow, analytics, and platform investment into governed operating outcomes."
  jsonLd={[webpageSchema, breadcrumbSchema]}
>
  <section class="hero" aria-labelledby="hero-title">
    <div class="container narrow">
      <span class="identity-mark" aria-hidden="true"><span></span></span>
      <p class="kicker">Enterprise AI · CRM/Salesforce · Workflow · Regulated Transformation</p>
      <h1 id="hero-title">Enterprise AI under control.</h1>
      <p class="lead hero-copy">
        AI, CRM/Salesforce, workflow, analytics, and platform investment turned into governed operating outcomes inside regulated enterprises.
      </p>
      <p class="credibility-line">
        Fortune 100 buyer-side execution. Global consulting pattern recognition. Regulated financial-services depth.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/executive-profile">View Executive Profile</a>
        <a class="button secondary" href="/enterprise-ai-transformation">Read Enterprise AI Point of View</a>
      </div>
    </div>
  </section>

  <section class="section compact" aria-labelledby="proof-title">
    <div class="container">
      <div class="proof-line">
        <h2 id="proof-title">Operating proof spans</h2>
        <p>
          Enterprise service platforms / CRM &amp; Salesforce / workflow modernization / analytics / platform reliability / AI-enabled operations / regulated transformation / global consulting mandates
        </p>
      </div>
    </div>
  </section>

  <section class="section alt" aria-labelledby="lanes-title">
    <div class="container">
      <div class="section-heading">
        <div class="intro">
          <p class="kicker">Where the work lands</p>
          <h2 id="lanes-title">Three operating lanes.</h2>
        </div>
      </div>
      <div class="lane-grid">
        <article class="lane-card">
          <span class="lane-number">01</span>
          <h3>Enterprise AI execution</h3>
          <p>Moving AI from pilots and demos into governed workflow patterns.</p>
        </article>
        <article class="lane-card">
          <span class="lane-number">02</span>
          <h3>CRM, workflow, and enterprise applications</h3>
          <p>Modernizing the systems where regulated work actually moves.</p>
        </article>
        <article class="lane-card">
          <span class="lane-number">03</span>
          <h3>Regulated transformation</h3>
          <p>Building change inside risk, compliance, control, adoption, and operating realities.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="insights-title">
    <div class="container">
      <div class="section-heading">
        <div class="intro">
          <p class="kicker">Selected insights</p>
          <h2 id="insights-title">Field notes on enterprise AI, CRM, workflow, and regulated operating change.</h2>
        </div>
        <a class="text-link" href="/insights">View all insights</a>
      </div>
      <div class="insight-grid">
        <article class="insight-card">
          <p class="tag">Enterprise AI</p>
          <h3><a href="/insights/ai-moved-from-assistance-to-execution-operating-model-has-not">AI Has Moved From Assistance to Execution. The Operating Model Has Not.</a></h3>
          <p>A board-level operating note on controlled autonomy, evidence discipline, and workflow ownership.</p>
        </article>
        <article class="insight-card">
          <p class="tag">CRM</p>
          <h3><a href="/insights/crm-trap-systems-of-record-never-become-systems-of-action">The CRM Trap: When Systems of Record Never Become Systems of Action.</a></h3>
          <p>Why CRM only creates value when it becomes part of how work moves, decisions get made, and outcomes are governed.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="cta-title">
    <div class="container narrow">
      <div class="cta-box">
        <h2 id="cta-title">For board, CXO, executive search, consulting, and enterprise AI conversations.</h2>
        <p>Connect directly on LinkedIn with context on the mandate.</p>
        <a class="button" href="https://www.linkedin.com/in/chandra-kanojia/" target="_blank" rel="noopener noreferrer">Connect on LinkedIn</a>
      </div>
    </div>
  </section>
</PageLayout>
