---
import PageLayout from '../layouts/PageLayout.astro';
---
<PageLayout title="Page Not Found | Chandra Kanojia" description="The requested page could not be found." noIndex={true}>
  <section class="page-hero" aria-labelledby="not-found-title">
    <div class="container narrow">
      <p class="kicker">404</p>
      <h1 id="not-found-title">Page not found.</h1>
      <p class="lead">The page you are looking for may have moved.</p>
      <div class="hero-actions">
        <a class="button primary" href="/">Return Home</a>
        <a class="button secondary" href="/executive-profile">View Profile</a>
      </div>
    </div>
  </section>
</PageLayout>
