---
import PageLayout from '../layouts/PageLayout.astro';

const profileSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': 'https://chandrakanojia.com/executive-profile/#profilepage',
  url: 'https://chandrakanojia.com/executive-profile',
  name: 'Chandra Kanojia Executive Profile',
  description: 'Executive profile for Chandra Kanojia, focused on enterprise AI, CRM/Salesforce, workflow transformation, regulated financial services, platform reliability, governance, and operating-model execution.',
  mainEntity: { '@id': 'https://chandrakanojia.com/#person' }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://chandrakanojia.com' },
    { '@type': 'ListItem', position: 2, name: 'Executive Profile', item: 'https://chandrakanojia.com/executive-profile' }
  ]
};
---
<PageLayout
  title="Chandra Kanojia | Enterprise AI, CRM & Regulated Transformation"
  description="Chandra Kanojia is an enterprise AI and regulated-transformation operator focused on AI, CRM/Salesforce, workflow, analytics, platform reliability, governance, and operating outcomes."
  canonical="https://chandrakanojia.com/executive-profile"
  jsonLd={[profileSchema, breadcrumbSchema]}
>
  <section class="page-hero profile-hero" aria-labelledby="profile-title">
    <div class="container hero-grid">
      <div>
        <p class="kicker">Executive Profile</p>
        <h1 id="profile-title">The mandate is execution, not experimentation.</h1>
        <p class="lead">
          Chandra Kanojia is an enterprise AI and regulated-transformation operator with a career arc from global consulting to Fortune 100 buyer-side execution.
        </p>
        <p class="body-large profile-summary">
          His work focuses on the systems where enterprise change becomes real: AI-enabled workflow, CRM/Salesforce, analytics, service platforms, governance, adoption, and operating-model execution.
        </p>
      </div>
      <aside class="mandate-panel compact-panel" aria-label="Executive distinction">
        <p class="panel-label">Distinction</p>
        <p>
          Consulting-grade pattern recognition, buyer-side operating proof, regulated-enterprise judgment, and a record of converting platform and AI investment into measurable operating outcomes.
        </p>
      </aside>
    </div>
  </section>

  <section class="section compact" aria-labelledby="profile-proof">
    <div class="container">
      <div class="authority-band">
        <p class="band-label" id="profile-proof">Operating proof categories</p>
        <p>
          Fortune 100 regulated environments · Salesforce/CRM modernization · enterprise workflow and case management · analytics and governance · service and advisor platforms · platform reliability · global consulting transformation mandates · insurance, retirement, brokerage, healthcare, and claims exposure
        </p>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="profile-mandates">
    <div class="container">
      <div class="section-heading compact-heading">
        <p class="kicker">Mandates Chandra is credible to lead</p>
        <h2 id="profile-mandates">Where the profile becomes useful.</h2>
      </div>
      <div class="mandate-grid">
        <article class="mandate-card">
          <span>01</span>
          <h3>AI execution inside regulated work</h3>
          <p>Move from pilots and demos into governed workflow patterns business leaders can fund, adopt, scale, and defend.</p>
        </article>
        <article class="mandate-card">
          <span>02</span>
          <h3>CRM, workflow, and enterprise applications</h3>
          <p>Modernize CRM, case management, analytics, advisor platforms, service operations, and workflow systems where work actually moves.</p>
        </article>
        <article class="mandate-card">
          <span>03</span>
          <h3>Regulated operating leverage</h3>
          <p>Reduce friction, improve experience, strengthen controls, and create executive confidence in complex enterprise change.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section alt" aria-labelledby="career-title">
    <div class="container">
      <div class="section-heading compact-heading">
        <p class="kicker">Career arc</p>
        <h2 id="career-title">Global consulting pattern recognition. Fortune 100 execution.</h2>
      </div>
      <div class="career-list">
        <article class="career-row">
          <h3>Fidelity Investments</h3>
          <p>Buyer-side execution across AI-enabled workflow, Salesforce/CRM, analytics, service platforms, governance, advisor and associate enablement, and platform reliability.</p>
        </article>
        <article class="career-row">
          <h3>Accenture</h3>
          <p>Strategy and transformation advisory across customer, sales, service, CRM, operating model, and value-realization mandates.</p>
        </article>
        <article class="career-row">
          <h3>Cognizant</h3>
          <p>North America financial-services digital consulting leadership, including advisory revenue generation, CXO relationships, and transformation demand shaping.</p>
        </article>
        <article class="career-row">
          <h3>Virtusa and early Cognizant consulting</h3>
          <p>Global insurance, healthcare, underwriting, claims, legal, and financial-services transformation across the US, UK, Germany, and South Asia.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="development-title">
    <div class="container dev-section">
      <div>
        <p class="kicker">Education &amp; Development</p>
        <h2 id="development-title">Business strategy, technology governance, and AI product fluency.</h2>
      </div>
      <div class="dev-list">
        <p><strong>Education:</strong> IIM Bangalore, MBA; Carnegie Mellon University, CIO Program; NIT Allahabad, B.Tech.</p>
        <p><strong>Executive development:</strong> BCG Digital Leader; Carnegie Mellon CIO Program.</p>
        <p><strong>AI and product fluency:</strong> Product Management; AI Product Management; AI Product Strategy; Advanced AI Agents; AI Evals; Claude Code / AI-enabled development workflows.</p>
        <p><strong>Additional credentials and exposure:</strong> AI Generalist; Lean Six Sigma Black Belt; SAFe Agile; Certified ScrumMaster; PMP; TOGAF 9; Zachman Enterprise Architecture; Design Thinking; Salesforce and Pega exposure.</p>
      </div>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="profile-cta">
    <div class="container">
      <div class="cta-box mandate-cta">
        <div>
          <p class="panel-label">Discuss the mandate</p>
          <h2 id="profile-cta">Useful conversations start with the operating problem.</h2>
          <p>AI execution, CRM and workflow modernization, regulated operating leverage, platform reliability, governance, and executive confidence in adoption and outcomes.</p>
        </div>
        <a class="button" href="https://www.linkedin.com/in/chandra-kanojia/" target="_blank" rel="noopener noreferrer">Connect on LinkedIn</a>
      </div>
    </div>
  </section>
</PageLayout>
