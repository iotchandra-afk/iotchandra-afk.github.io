---
import PageLayout from '../layouts/PageLayout.astro';

const profilePageSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": { "@id": "https://chandrakanojia.com/#person" },
  "url": "https://chandrakanojia.com/executive-profile",
  "name": "Chandra Kanojia | Enterprise AI, CRM & Financial Services Transformation Executive",
  "description": "Enterprise AI and regulated-transformation operator focused on AI, CRM/Salesforce, workflow, analytics, platform reliability, governance, and measurable operating outcomes."
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://chandrakanojia.com" },
    { "@type": "ListItem", "position": 2, "name": "Executive Profile", "item": "https://chandrakanojia.com/executive-profile" }
  ]
};
---

<PageLayout
  title="Chandra Kanojia | Enterprise AI, CRM & Financial Services Transformation Executive"
  description="Enterprise AI and regulated-transformation operator focused on AI, CRM/Salesforce, workflow, analytics, platform reliability, governance, and measurable operating outcomes."
  jsonLd={[profilePageSchema, breadcrumbSchema]}
>
  <section class="page-header" aria-labelledby="profile-heading">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb" role="list">
          <li><a href="/">Home</a></li>
          <li aria-hidden="true" style="color: var(--color-text-muted); margin: 0 0.5rem;">·</li>
          <li aria-current="page">Executive Profile</li>
        </ol>
      </nav>
      <h1 class="page-title" id="profile-heading">Executive Profile</h1>
      <p class="page-lede">
        Enterprise AI, CRM/Salesforce, workflow, analytics, and regulated transformation — with proof across consulting-side demand shaping and Fortune 100 buyer-side execution.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="summary-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-overline" aria-hidden="true">Executive Summary</p>
        <h2 class="section-title" id="summary-heading">Enterprise AI that has to work inside complex institutions.</h2>
      </div>
      <div class="prose">
        <p>
          Chandra Kanojia is an enterprise AI and regulated-transformation operator with a career arc from global consulting to Fortune 100 buyer-side execution. His work focuses on turning AI, CRM/Salesforce, workflow, analytics, and platform investment into measurable operating outcomes.
        </p>
        <p>
          His strongest lane is where enterprise AI has to become real inside complex institutions: governed workflows, adoption, platform reliability, cost-to-serve reduction, advisor and associate productivity, risk discipline, and executive delivery confidence.
        </p>
        <p>
          Chandra’s distinction is practical: consulting-grade pattern recognition, Fortune 100 buyer-side operating proof, regulated-enterprise judgment, and a record of converting platform and AI investment into measurable operating outcomes.
        </p>
      </div>
    </div>
  </section>

  <section class="metric-band" aria-label="Operating proof">
    <div class="container">
      <div class="metric-band-inner" role="list">
        <div class="metric-cell" role="listitem"><span class="metric-value">7.2M+</span><span class="metric-label">Service cases managed</span></div>
        <div class="metric-cell" role="listitem"><span class="metric-value">37%</span><span class="metric-label">Year-over-year growth supported</span></div>
        <div class="metric-cell" role="listitem"><span class="metric-value">99.5%</span><span class="metric-label">Platform availability</span></div>
        <div class="metric-cell" role="listitem"><span class="metric-value">$15M–$20M</span><span class="metric-label">Delivery portfolio</span></div>
        <div class="metric-cell" role="listitem"><span class="metric-value">$500M+</span><span class="metric-label">Transformation-program scale</span></div>
        <div class="metric-cell" role="listitem"><span class="metric-value">$112M</span><span class="metric-label">Process-savings contribution</span></div>
        <div class="metric-cell" role="listitem"><span class="metric-value">$8M–$12M</span><span class="metric-label">Advisory revenue generated</span></div>
        <div class="metric-cell" role="listitem"><span class="metric-value">$10M–$300M</span><span class="metric-label">Pull-through deal influence</span></div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="value-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-overline" aria-hidden="true">Where Chandra Creates Value</p>
        <h2 class="section-title" id="value-heading">Six places where the operating proof is specific.</h2>
      </div>
      <div class="value-grid" role="list">
        <article class="value-card" role="listitem"><h3>Enterprise AI scaling</h3><p>Moving AI from pilots and demos into governed workflow patterns business leaders can fund, adopt, and reuse.</p></article>
        <article class="value-card" role="listitem"><h3>Human-agent workflow redesign</h3><p>Designing operating models where people, platforms, data, and AI-enabled work move with clear decision rights, controls, and accountability.</p></article>
        <article class="value-card" role="listitem"><h3>CRM / Salesforce modernization</h3><p>Turning CRM from a system of record into a system of action for advisors, associates, service teams, and relationship leaders.</p></article>
        <article class="value-card" role="listitem"><h3>Enterprise workflow and application modernization</h3><p>Improving how work moves across CRM, case management, analytics, service operations, advisor platforms, and large enterprise applications.</p></article>
        <article class="value-card" role="listitem"><h3>Cost-to-serve and productivity</h3><p>Reducing operating friction while improving service quality, advisor effectiveness, associate experience, and execution confidence.</p></article>
        <article class="value-card" role="listitem"><h3>Regulated transformation</h3><p>Building change inside financial-services, insurance, retirement, brokerage, healthcare, risk, compliance, and control realities.</p></article>
      </div>
    </div>
  </section>

  <section class="section section--surface" aria-labelledby="career-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-overline" aria-hidden="true">Career Arc</p>
        <h2 class="section-title" id="career-heading">From consulting-side transformation to Fortune 100 buyer-side execution.</h2>
      </div>
      <div class="theme-grid" role="list">
        <article class="theme-cell" role="listitem"><h3>Fidelity Investments</h3><p>Fortune 100 buyer-side execution across AI-enabled workflow, Salesforce/CRM, analytics, service platforms, governance, advisor and associate enablement, and platform reliability.</p></article>
        <article class="theme-cell" role="listitem"><h3>Accenture</h3><p>Strategy and transformation advisory across customer, sales, service, CRM, operating model, and value realization mandates.</p></article>
        <article class="theme-cell" role="listitem"><h3>Cognizant</h3><p>North America financial-services digital consulting leadership, including advisory revenue generation, CXO relationships, and transformation demand shaping.</p></article>
        <article class="theme-cell" role="listitem"><h3>Virtusa and early Cognizant consulting</h3><p>Global insurance, healthcare, underwriting, claims, legal, and financial-services transformation across the US, UK, Germany, and South Asia.</p></article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="education-heading">
    <div class="container">
      <div class="two-col">
        <div>
          <div class="section-header">
            <p class="section-overline" aria-hidden="true">Education & Development</p>
            <h2 class="section-title" id="education-heading">Business strategy, technology governance, AI product thinking, and enterprise execution.</h2>
          </div>
          <div class="prose">
            <p><strong>Education:</strong> IIM Bangalore, MBA. Carnegie Mellon University, CIO Program. NIT Allahabad, B.Tech.</p>
            <p><strong>Executive development:</strong> Carnegie Mellon CIO Program; BCG Digital Leader.</p>
            <p><strong>AI and product fluency:</strong> Product Management; AI Product Management; AI Product Strategy; Advanced AI Agents; AI Evals; Claude Code / AI-enabled development workflows.</p>
            <p><strong>Additional credentials and exposure:</strong> AI Generalist; Lean Six Sigma Black Belt; SAFe Agile; Certified ScrumMaster; PMP; TOGAF 9; Zachman Enterprise Architecture; Design Thinking; Salesforce and Pega exposure.</p>
          </div>
        </div>
        <div class="board-block">
          <p class="board-block-overline" aria-hidden="true">Executive Snapshot</p>
          <p>
            Focus: enterprise AI, CRM/Salesforce, workflow, analytics, governance, platform reliability, and regulated operating outcomes.
          </p>
          <p>
            Enterprise application exposure: CRM/Salesforce, CRM Analytics, workflow platforms, case management, analytics, service operations, advisor enablement, enterprise communications, and platform modernization.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface" aria-labelledby="profile-cta-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-overline" aria-hidden="true">Connect</p>
        <h2 class="section-title" id="profile-cta-heading">For the right enterprise AI, CRM, workflow, or regulated-transformation mandate.</h2>
        <p class="section-body">Executive search partners, CXO hiring leaders, board members, consulting firms, and enterprise AI companies are welcome to connect directly on LinkedIn.</p>
      </div>
      <div class="hero-actions">
        <a href="/contact" class="btn btn--primary">Connect on LinkedIn</a>
        <a href="/enterprise-ai-transformation" class="btn btn--ghost">Enterprise AI Perspective</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
.breadcrumb { display: flex; align-items: center; list-style: none; padding: 0; margin: 0 0 var(--space-8); font-family: var(--font-mono); font-size: var(--text-mono); letter-spacing: var(--ls-wide); color: var(--color-text-muted); }
.breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
.breadcrumb a:hover { color: var(--color-text-primary); }
</style>
