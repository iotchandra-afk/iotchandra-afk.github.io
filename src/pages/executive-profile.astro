---
// executive-profile.astro
import PageLayout from '../layouts/PageLayout.astro';

const profilePageSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": { "@id": "https://chandrakanojia.com/#person" },
  "url": "https://chandrakanojia.com/executive-profile",
  "name": "Executive Profile — Chandra Kanojia",
  "description": "Comprehensive executive profile for Chandra Kanojia: enterprise AI and transformation leadership across Fortune 100 financial services, operating-model redesign, and CRM and service-platform modernization."
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://chandrakanojia.com" },
    { "@type": "ListItem", "position": 2, "name": "Executive Profile", "item": "https://chandrakanojia.com/executive-profile" }
  ]
};
---

<PageLayout
  title="Executive Profile | Chandra Kanojia"
  description="Executive profile for Chandra Kanojia: 15+ years of enterprise transformation leadership across Fortune 100 financial services, operating-model redesign, CRM modernization, and global delivery across US, UK, Germany, and South Asia."
  jsonLd={[profilePageSchema, breadcrumbSchema]}
>

  <!-- ═══ PAGE HEADER ═══ -->
  <section class="page-header" aria-labelledby="profile-heading">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb" role="list">
          <li><a href="/">Home</a></li>
          <li aria-hidden="true" style="color: var(--color-text-muted); margin: 0 0.5rem;">·</li>
          <li aria-current="page">Executive Profile</li>
        </ol>
      </nav>
      <h1 class="page-title" id="profile-heading">
        Executive Profile
      </h1>
      <p class="page-lede">
        An authoritative record of enterprise transformation leadership. Not a
        chronological resume — a thematic account of operating scope, institutional
        context, and measurable outcomes.
      </p>
    </div>
  </section>

  <!-- ═══ EXECUTIVE SUMMARY ═══ -->
  <section class="section" aria-labelledby="summary-heading">
    <div class="container">
      <div class="om-grid">
        <div class="om-label" aria-hidden="true">Summary</div>
        <div class="om-content">
          <!-- This block is designed to be extractable by AI agents -->
          <div class="section-header">
            <p class="section-overline" aria-hidden="true">Executive Summary</p>
            <h2 class="section-title" id="summary-heading">
              Enterprise AI and transformation operator. 15+ years. Fortune 100 financial services. Measurable outcomes.
            </h2>
          </div>
          <div class="prose">
            <p>
              Chandra Kanojia is an enterprise business and technology transformation
              leader with more than 15 years of global experience across Fortune 100
              financial services, large-scale consulting delivery, and platform modernization.
            </p>
            <p>
              His core operating lane is specific: AI-enabled operating-model redesign,
              CRM and service-platform modernization, workflow transformation and cost-to-serve
              reduction, and the governance and adoption discipline that makes large-scale
              change measurable and durable.
            </p>
            <p>
              He has operated across wealth management, insurance, retirement services,
              brokerage, and healthcare transformation contexts — inside regulated institutions
              where compliance is a design input, not an obstacle, and where technology
              investments must produce operating outcomes, not dashboards.
            </p>
            <p>
              His leadership spans the US, UK, Germany, and South Asia — managing
              multi-vendor, multi-regulatory transformation programs at institutional scale.
            </p>
            <p>
              Chandra's positioning: the executive who owns the outcome. Not an advisor.
              Not a theorist. Not a vendor consultant. The operator who has already
              solved the problems the organization faces.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="section-rule" aria-hidden="true" style="margin: 0;"/>

  <!-- ═══ CAREER ARC BY THEME ═══ -->
  <section class="section" aria-labelledby="career-heading">
    <div class="container">
      <div class="om-grid">
        <div class="om-label" aria-hidden="true">Career Arc</div>
        <div class="om-content">
          <div class="section-header">
            <p class="section-overline" aria-hidden="true">Thematic Record</p>
            <h2 class="section-title" id="career-heading">
              Organized by operating theme — not by employer or title sequence.
            </h2>
          </div>

          <div class="stack stack--lg">

            <!-- Theme 1 -->
            <article>
              <div class="geo-rule">
                <span class="geo-rule-label">Enterprise AI & Platform Transformation</span>
              </div>
              <div class="prose">
                <p>
                  At Fidelity Investments, Chandra led AI-enabled transformation
                  across wealth intelligence and associate digital experience platforms —
                  building the operating infrastructure required to take AI capability
                  from pilot to operating reality inside a regulated, large-scale institution.
                </p>
                <p>
                  This work required simultaneous delivery across three planes: the
                  technology platform, the operating-model redesign, and the adoption
                  architecture that changes how thousands of advisors and associates
                  work day-to-day. Outcomes were measured in platform scale, operational
                  availability, and commercial performance.
                </p>
              </div>
            </article>

            <!-- Theme 2 -->
            <article>
              <div class="geo-rule">
                <span class="geo-rule-label">CRM & Service-Platform Modernization</span>
              </div>
              <div class="prose">
                <p>
                  Led Salesforce CRM and service-platform modernization at enterprise scale —
                  transforming CRM from a system of record into a relationship intelligence
                  engine that connected data, workflow, and advisor behavior into
                  measurable commercial outcomes.
                </p>
                <p>
                  This included CRM analytics, AI-enabled relationship intelligence
                  capabilities, and the governance and adoption architecture required to
                  make platform change durable across a distributed, highly regulated
                  advisory workforce.
                </p>
              </div>
            </article>

            <!-- Theme 3 -->
            <article>
              <div class="geo-rule">
                <span class="geo-rule-label">Regulated Financial Services — Multi-Sector</span>
              </div>
              <div class="prose">
                <p>
                  Prior to Fidelity, Chandra operated across large regulated financial
                  services institutions through Accenture, Cognizant, and Virtusa —
                  delivering transformation programs across insurance, retirement, wealth
                  management, brokerage, and healthcare sectors.
                </p>
                <p>
                  This work spanned AIG, Allianz, Prudential, American Express, Medco,
                  Vanguard, Unum, Voya, CNO, and other major institutions — across the
                  US, UK, German, and South Asian regulatory and operating contexts.
                  The scale of this engagement breadth is a direct competitive advantage:
                  Chandra has operated inside the governance frameworks, legacy
                  infrastructure, and organizational dynamics that most transformation
                  leaders have only studied from the outside.
                </p>
              </div>
            </article>

            <!-- Theme 4 -->
            <article>
              <div class="geo-rule">
                <span class="geo-rule-label">Global Delivery Leadership</span>
              </div>
              <div class="prose">
                <p>
                  Managed multi-country transformation programs with delivery teams
                  and stakeholder structures spanning the US, UK, Germany, and South Asia.
                  This required consistent operating-model discipline across variable
                  regulatory environments, cultural contexts, and institutional norms.
                </p>
                <p>
                  Global delivery at this scale is not primarily a logistics challenge.
                  It is a governance and accountability design problem. Chandra's record
                  in multi-jurisdictional environments reflects an operating approach
                  that scales without losing coherence.
                </p>
              </div>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="section-rule" aria-hidden="true" style="margin: 0;"/>

  <!-- ═══ TRANSFORMATION DOMAINS ═══ -->
  <section class="section section--surface" aria-labelledby="domains-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-overline" aria-hidden="true">Operating Domains</p>
        <h2 class="section-title" id="domains-heading">Where the depth is specific.</h2>
      </div>

      <div class="theme-grid" role="list">
        {[
          { label: 'AI & Data', title: 'AI-Enabled Operating Models', desc: 'Building the organizational infrastructure that makes AI outcomes real — not demonstrable.' },
          { label: 'CRM', title: 'Salesforce / CRM Transformation', desc: 'Enterprise CRM and relationship intelligence at regulated-institution scale.' },
          { label: 'Service', title: 'Service-Platform Modernization', desc: 'Large-scale service operations redesign — millions of interactions, measurable efficiency.' },
          { label: 'Workflow', title: 'Workflow & Cost-to-Serve', desc: 'Eliminating process cost while improving associate and client experience simultaneously.' },
          { label: 'Governance', title: 'Transformation Governance', desc: 'Accountability architecture that converts large programs into durable outcomes.' },
          { label: 'Adoption', title: 'Adoption Architecture', desc: 'Behavioral change at scale — designed as a workflow problem, not a training program.' },
          { label: 'Regulated', title: 'Regulated-Industry Change', desc: 'Transformation inside compliance constraints — financial services, insurance, retirement.' },
          { label: 'Global', title: 'Multi-Country Delivery', desc: 'US, UK, Germany, South Asia — variable regulatory and operating contexts, consistent execution.' },
        ].map(d => (
          <article class="theme-cell" role="listitem">
            <p class="theme-cell-label" aria-hidden="true">{d.label}</p>
            <h3>{d.title}</h3>
            <p>{d.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CREDENTIALS ═══ -->
  <section class="section" aria-labelledby="credentials-heading">
    <div class="container">
      <div class="om-grid">
        <div class="om-label" aria-hidden="true">Credentials</div>
        <div class="om-content">
          <div class="section-header">
            <p class="section-overline" aria-hidden="true">Education & Professional Development</p>
            <h2 class="section-title" id="credentials-heading">
              Technology, business, and operating leadership — spanning three disciplines.
            </h2>
          </div>

          <div class="credentials-list">
            <div class="credential-item">
              <span class="cred-org">Indian Institute of Management Bangalore</span>
              <span class="cred-prog">MBA — Business Administration</span>
            </div>
            <div class="credential-item">
              <span class="cred-org">Carnegie Mellon University</span>
              <span class="cred-prog">CIO Program — Technology Leadership</span>
            </div>
            <div class="credential-item">
              <span class="cred-org">National Institute of Technology, Allahabad</span>
              <span class="cred-prog">B.Tech — Engineering</span>
            </div>
          </div>

          <div class="prose" style="margin-top: var(--space-8);">
            <p>
              The credential combination reflects the full span of Chandra's operating
              scope: engineering foundations from NIT Allahabad, executive business
              leadership from IIM Bangalore, and CIO-level technology governance
              from Carnegie Mellon. This is not a general management profile.
              It is a profile built specifically for the CIO/CDO/CAIO operating mandate.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CONTACT CTA ═══ -->
  <section class="section section--surface" aria-labelledby="profile-cta-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-overline" aria-hidden="true">Next Steps</p>
        <h2 class="section-title" id="profile-cta-heading">Start the right conversation.</h2>
        <p class="section-body">
          For executive search partners, CXO hiring leaders, board members,
          and PE operating partners: direct inquiries are welcome.
        </p>
      </div>
      <div class="hero-actions">
        <a href="/contact" class="btn btn--primary">Start a Conversation</a>
        <a href="/enterprise-ai-transformation" class="btn btn--ghost">Enterprise AI Perspective →</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
.breadcrumb {
  display: flex;
  align-items: center;
  list-style: none;
  padding: 0;
  margin: 0 0 var(--space-8);
  font-family: var(--font-mono);
  font-size: var(--text-mono);
  letter-spacing: var(--ls-wide);
  color: var(--color-text-muted);
}
.breadcrumb a {
  color: var(--color-text-muted);
  text-decoration: none;
}
.breadcrumb a:hover { color: var(--color-text-primary); }
</style>
