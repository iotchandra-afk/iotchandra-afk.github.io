---
import PageLayout from '../layouts/PageLayout.astro';
import DiscussCTA from '../components/DiscussCTA.astro';

const profileSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': 'https://www.chandrakanojia.com/#profile',
  url: 'https://www.chandrakanojia.com/executive-profile',
  name: 'Chandra Kanojia Executive Profile',
  description: 'Official executive profile for Chandra Kanojia, an enterprise AI and platform transformation executive focused on governed workflows, CRM, operating intelligence, and financial services transformation.',
  mainEntity: { '@id': 'https://www.chandrakanojia.com/#chandra-kanojia' }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.chandrakanojia.com' },
    { '@type': 'ListItem', position: 2, name: 'Executive Profile', item: 'https://www.chandrakanojia.com/executive-profile' }
  ]
};
---
<PageLayout
  title="Chandra Kanojia | Enterprise AI, Data, CRM & Regulated Transformation"
  description="Official executive profile for Chandra Kanojia, an enterprise AI and platform transformation executive focused on governed workflows, CRM, operating intelligence, and financial services transformation."
  canonical="https://www.chandrakanojia.com/executive-profile"
  ogImage="/images/og-profile.png"
  jsonLd={[profileSchema, breadcrumbSchema]}
>
  <section class="page-hero profile-hero" aria-labelledby="profile-title">
    <div class="container narrow">
      <div>
        <p class="kicker">Executive Profile</p>
        <h1 id="profile-title">The hard part is changing work without breaking trust.</h1>
        <p class="lead">
          Chandra Kanojia is an enterprise AI and platform transformation executive focused on governed workflows, CRM, operating intelligence, and financial services transformation.
        </p>
        <p class="body-large profile-summary">
          He works where AI, data, CRM/Salesforce, workflow, analytics, and enterprise platforms have to become real operating change inside regulated institutions.
        </p>
        <p class="body-large profile-summary">
          His career arc spans global consulting and Fortune 100 buyer-side execution. The common thread is practical: make the system of work clearer, faster, safer, and easier to run.
        </p>
        <div class="profile-utility share-utility" aria-label="Sharing utility">
          <p class="share-label">For recruiter notes, speaker intros, and internal referrals</p>
          <button class="copy-button" type="button" data-copy-text="Chandra Kanojia is an enterprise AI and platform transformation executive focused on governed workflows, CRM, operating intelligence, and financial services transformation. He works where AI, data, CRM/Salesforce, workflow, analytics, and enterprise platforms have to become real operating change inside regulated institutions. His career arc combines global consulting pattern recognition with Fortune 100 buyer-side execution.">Copy executive summary</button>
        </div>
      </div>
    </div>
  </section>

  <section class="section compact" aria-labelledby="profile-proof">
    <div class="container">
      <div class="authority-band">
        <p class="band-label" id="profile-proof">Operating proof spans</p>
        <p>
          Regulated financial services · data readiness for AI · Salesforce/CRM modernization · workflow and case management · analytics and governance · service and advisor platforms · platform reliability · global consulting mandates · insurance, retirement, brokerage, healthcare, and claims transformation.
        </p>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="profile-mandates">
    <div class="container">
      <div class="section-heading compact-heading">
        <p class="kicker">Mandates Chandra is credible to lead</p>
        <h2 id="profile-mandates">Where the profile becomes useful.</h2>
      </div>
      <div class="mandate-grid">
        <article class="mandate-card">
          <span>01</span>
          <h3>Make AI useful beyond the demo</h3>
          <p>Move AI into real workflows with clear ownership, evidence, controls, adoption paths, and business accountability.</p>
        </article>
        <article class="mandate-card">
          <span>02</span>
          <h3>Modernize CRM and workflow systems</h3>
          <p>Improve the systems where work moves: CRM, case management, service platforms, advisor enablement, analytics, and enterprise workflow.</p>
        </article>
        <article class="mandate-card">
          <span>03</span>
          <h3>Make data usable at the decision point</h3>
          <p>Close the gap between data that exists somewhere and data that is trusted when people, systems, and AI need to act.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section alt" aria-labelledby="career-title">
    <div class="container">
      <div class="section-heading compact-heading">
        <p class="kicker">Career arc</p>
        <h2 id="career-title">Consulting pattern recognition. Operator-side execution.</h2>
      </div>
      <div class="career-list">
        <article class="career-row">
          <h3>Fidelity Investments</h3>
          <p>Buyer-side execution across AI-enabled workflow, Salesforce/CRM, analytics, service platforms, governance, advisor and associate enablement, data context, and platform reliability.</p>
        </article>
        <article class="career-row">
          <h3>Accenture</h3>
          <p>Strategy and transformation advisory across customer, sales, service, CRM, operating model, and value-realization work.</p>
        </article>
        <article class="career-row">
          <h3>Cognizant</h3>
          <p>North America financial-services digital consulting leadership, CXO relationships, advisory demand shaping, and transformation-market credibility.</p>
        </article>
        <article class="career-row">
          <h3>Virtusa and early Cognizant consulting</h3>
          <p>Global insurance, healthcare, underwriting, claims, legal, and financial-services transformation across the US, UK, Germany, and South Asia.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="development-title">
    <div class="container dev-section">
      <div>
        <p class="kicker">Education &amp; Development</p>
        <h2 id="development-title">Business strategy, technology governance, and AI product judgment.</h2>
      </div>
      <div class="dev-list compact-dev">
        <p><strong>Education:</strong> IIM Bangalore, MBA; Carnegie Mellon University, CIO Program; NIT Allahabad, B.Tech.</p>
        <p><strong>Executive development:</strong> BCG Digital Leader; AI product strategy; product management; enterprise architecture; Salesforce/CRM exposure.</p>
        <p class="muted-note">Additional delivery credentials and technical training are available in the executive profile shared for relevant conversations.</p>
      </div>
    </div>
  </section>
  <DiscussCTA
    id="profile-cta"
    eyebrow="Discuss the mandate"
    title="Start with the operating problem."
    body="Relevant conversations include AI execution, data readiness, CRM/Salesforce and workflow modernization, platform reliability, governance, adoption, and measurable business value."
  />
</PageLayout>
