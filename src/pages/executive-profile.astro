---
import PageLayout from '../layouts/PageLayout.astro';

const profileSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': 'https://chandrakanojia.com/executive-profile/#profilepage',
  url: 'https://chandrakanojia.com/executive-profile',
  name: 'Chandra Kanojia Executive Profile',
  description: 'Executive profile for Chandra Kanojia, focused on enterprise AI, CRM/Salesforce, workflow transformation, regulated financial services, platform reliability, governance, and operating-model execution.',
  mainEntity: { '@id': 'https://chandrakanojia.com/#person' }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://chandrakanojia.com' },
    { '@type': 'ListItem', position: 2, name: 'Executive Profile', item: 'https://chandrakanojia.com/executive-profile' }
  ]
};
---
<PageLayout
  title="Chandra Kanojia | Enterprise AI, CRM & Regulated Transformation"
  description="Chandra Kanojia is an enterprise AI and regulated-transformation operator focused on AI, CRM/Salesforce, workflow, analytics, platform reliability, governance, and operating outcomes."
  canonical="https://chandrakanojia.com/executive-profile"
  jsonLd={[profileSchema, breadcrumbSchema]}
>
  <section class="page-hero" aria-labelledby="profile-title">
    <div class="container narrow">
      <p class="kicker">Executive Profile</p>
      <h1 id="profile-title">Enterprise AI and regulated transformation.</h1>
      <p class="lead">
        Chandra Kanojia has a career arc from global consulting to Fortune 100 buyer-side execution. His work focuses on turning AI, CRM/Salesforce, workflow, analytics, and platform investment into measurable operating outcomes.
      </p>
      <p class="body-large" style="margin-top:1rem;">
        His strongest lane is where enterprise AI has to become real inside complex institutions: governed workflows, adoption, platform reliability, cost-to-serve reduction, advisor and associate productivity, risk discipline, and executive delivery confidence.
      </p>
    </div>
  </section>

  <section class="section compact" aria-labelledby="profile-proof">
    <div class="container">
      <div class="proof-line">
        <h2 id="profile-proof">Operating proof spans</h2>
        <p>
          Enterprise service platforms / CRM &amp; Salesforce modernization / workflow and case management / analytics / platform reliability / AI-enabled operations / regulated financial-services transformation / global consulting mandates
        </p>
      </div>
    </div>
  </section>

  <section class="section alt" aria-labelledby="value-title">
    <div class="container">
      <div class="section-heading">
        <div class="intro">
          <p class="kicker">Deployment map</p>
          <h2 id="value-title">Where Chandra creates value.</h2>
        </div>
      </div>
      <div class="lane-grid">
        <article class="lane-card">
          <span class="lane-number">01</span>
          <h3>Enterprise AI execution</h3>
          <p>Moving AI from pilots and demos into governed workflow patterns business leaders can fund, adopt, and scale.</p>
        </article>
        <article class="lane-card">
          <span class="lane-number">02</span>
          <h3>CRM, workflow, and enterprise applications</h3>
          <p>Modernizing CRM, case management, analytics, advisor platforms, service operations, and workflow systems where regulated work actually moves.</p>
        </article>
        <article class="lane-card">
          <span class="lane-number">03</span>
          <h3>Regulated transformation</h3>
          <p>Building change inside financial-services, insurance, retirement, brokerage, healthcare, risk, compliance, and control realities.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="career-title">
    <div class="container">
      <div class="section-heading">
        <div class="intro">
          <p class="kicker">Career arc</p>
          <h2 id="career-title">Consulting pattern recognition. Buyer-side execution.</h2>
        </div>
      </div>
      <div class="career-list">
        <article class="career-row">
          <h3>Fidelity Investments</h3>
          <p>Fortune 100 buyer-side execution across AI-enabled workflow, Salesforce/CRM, analytics, service platforms, governance, advisor and associate enablement, and platform reliability.</p>
        </article>
        <article class="career-row">
          <h3>Accenture</h3>
          <p>Strategy and transformation advisory across customer, sales, service, CRM, operating model, and value-realization mandates.</p>
        </article>
        <article class="career-row">
          <h3>Cognizant</h3>
          <p>North America financial-services digital consulting leadership, including advisory revenue generation, CXO relationships, and transformation demand shaping.</p>
        </article>
        <article class="career-row">
          <h3>Virtusa and early Cognizant consulting</h3>
          <p>Global insurance, healthcare, underwriting, claims, legal, and financial-services transformation across the US, UK, Germany, and South Asia.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section alt" aria-labelledby="development-title">
    <div class="container dev-section">
      <div>
        <p class="kicker">Education &amp; Development</p>
        <h2 id="development-title">Business strategy, technology governance, and AI product fluency.</h2>
      </div>
      <div class="dev-list">
        <p><strong>Education:</strong> IIM Bangalore, MBA; Carnegie Mellon University, CIO Program; NIT Allahabad, B.Tech.</p>
        <p><strong>Executive development:</strong> BCG Digital Leader; Carnegie Mellon CIO Program.</p>
        <p><strong>AI and product fluency:</strong> Product Management; AI Product Management; AI Product Strategy; Advanced AI Agents; AI Evals; Claude Code / AI-enabled development workflows.</p>
        <p><strong>Additional credentials and exposure:</strong> AI Generalist; Lean Six Sigma Black Belt; SAFe Agile; Certified ScrumMaster; PMP; TOGAF 9; Zachman Enterprise Architecture; Design Thinking; Salesforce and Pega exposure.</p>
      </div>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="profile-cta">
    <div class="container narrow">
      <div class="cta-box">
        <h2 id="profile-cta">Discuss the mandate.</h2>
        <p>For board, CXO, executive search, consulting, and enterprise AI conversations, connect directly on LinkedIn.</p>
        <a class="button" href="https://www.linkedin.com/in/chandra-kanojia/" target="_blank" rel="noopener noreferrer">Connect on LinkedIn</a>
      </div>
    </div>
  </section>
</PageLayout>
