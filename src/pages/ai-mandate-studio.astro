---
import PageLayout from '../layouts/PageLayout.astro';

const webpageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://chandrakanojia.com/ai-mandate-studio/#webpage',
  url: 'https://chandrakanojia.com/ai-mandate-studio',
  name: 'AI Mandate Studio | Chandra Kanojia',
  description: 'A curated, executive-safe studio showing how enterprise AI mandates can be framed around workflow, evidence, controls, adoption, and outcomes.',
  isPartOf: { '@id': 'https://chandrakanojia.com/#website' },
  about: { '@id': 'https://chandrakanojia.com/#person' }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://chandrakanojia.com' },
    { '@type': 'ListItem', position: 2, name: 'AI Mandate Studio', item: 'https://chandrakanojia.com/ai-mandate-studio' }
  ]
};

const mandates = [
  {
    id: 'demo',
    title: 'Move AI beyond the demo',
    short: 'The enterprise has AI tools, but the work has not changed.',
    issue: 'The demo proves capability. It does not prove adoption, control, or business value.',
    where: 'Inside the workflow, close to CRM, case management, analytics, service platforms, and operating routines.',
    design: 'Context, permissions, evidence, escalation, change management, and ownership for the outcome.',
    leaders: 'Cycle time, capacity created, quality, risk exceptions, adoption, experience, and business value.',
    board: 'Can management explain how AI changes work without weakening control?'
  },
  {
    id: 'crm',
    title: 'Modernize CRM and workflow',
    short: 'The system records activity, but it does not always change what happens next.',
    issue: 'CRM becomes expensive shelfware when it stores effort without improving decisions or follow-through.',
    where: 'In the handoff between relationship context, service work, prioritization, next action, and evidence capture.',
    design: 'Clear ownership, better data discipline, fewer swivel-chair steps, embedded prompts, and action-oriented workflows.',
    leaders: 'Adoption, rework, first-touch resolution, cycle time, next-action quality, and service experience.',
    board: 'Is the enterprise using CRM as a record of effort, or as a system that improves decisions?'
  },
  {
    id: 'capacity',
    title: 'Create capacity without adding complexity',
    short: 'Teams are busy, tools are multiplying, and the work still feels heavy.',
    issue: 'AI can reduce friction, but only if it removes work instead of adding another layer of coordination.',
    where: 'In preparation, routing, follow-up, exception handling, case summarization, and manager visibility.',
    design: 'A smaller number of cleaner workflows, clear decision rights, trusted evidence, and human review only where it matters.',
    leaders: 'Capacity released, cycle time, backlog age, associate effort, quality, and customer experience.',
    board: 'Is AI reducing the burden of work, or creating a new operating layer to manage?'
  },
  {
    id: 'controls',
    title: 'Strengthen controls and confidence',
    short: 'AI cannot scale in regulated work if leaders cannot explain how it acts.',
    issue: 'Confidence comes from evidence, permission boundaries, audit paths, and escalation—not from fluent output.',
    where: 'In the control points around recommendations, communications, exception handling, data access, and recordkeeping.',
    design: 'Evidence standards, role-based permissions, escalation triggers, review paths, monitoring, and clear accountability.',
    leaders: 'Risk events, override rates, audit completeness, escalation quality, policy adherence, and management confidence.',
    board: 'Can the enterprise defend how AI reached the answer and what action followed?'
  }
];
---
<PageLayout
  title="AI Mandate Studio | Chandra Kanojia"
  description="A curated, executive-safe studio showing how enterprise AI mandates can be framed around workflow, evidence, controls, adoption, and outcomes."
  canonical="https://chandrakanojia.com/ai-mandate-studio"
  jsonLd={[webpageSchema, breadcrumbSchema]}
>
  <section class="page-hero" aria-labelledby="studio-title">
    <div class="container narrow">
      <p class="kicker">AI Mandate Studio</p>
      <h1 id="studio-title">The demo is the easy part.</h1>
      <p class="lead">
        This studio shows how a senior AI conversation changes when the question moves from capability to work: where AI enters, what it uses, what it can do, when a human returns, and how leaders know the outcome improved.
      </p>
      <p class="studio-note">
        Curated. Public-safe. No live model. No confidential data. The point is judgment, not novelty.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="studio-workspace">
    <div class="container studio-workspace">
      <div class="studio-left">
        <p class="kicker">Choose a mandate</p>
        <h2 id="studio-workspace">What problem are you trying to make real?</h2>
        <div class="studio-options" role="tablist" aria-label="Enterprise AI mandates">
          {mandates.map((item, index) => (
            <button
              class={`studio-option ${index === 0 ? 'active' : ''}`}
              type="button"
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              data-mandate={item.id}
            >
              <strong>{item.title}</strong>
              <span>{item.short}</span>
            </button>
          ))}
        </div>
      </div>

      <div class="studio-output" aria-live="polite">
        <p class="panel-label">Mandate brief</p>
        <h2 id="studio-output-title">{mandates[0].title}</h2>
        <dl>
          <div><dt>The real issue</dt><dd id="studio-issue">{mandates[0].issue}</dd></div>
          <div><dt>Where AI belongs</dt><dd id="studio-where">{mandates[0].where}</dd></div>
          <div><dt>What must be designed</dt><dd id="studio-design">{mandates[0].design}</dd></div>
          <div><dt>What leaders should track</dt><dd id="studio-leaders">{mandates[0].leaders}</dd></div>
          <div><dt>Board question</dt><dd id="studio-board">{mandates[0].board}</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="studio-cta">
    <div class="container">
      <div class="cta-box mandate-cta">
        <div>
          <p class="panel-label">Discuss the mandate</p>
          <h2 id="studio-cta">The useful question is not whether AI can answer. It is whether the enterprise can change the work safely enough to make the answer matter.</h2>
          <p>For AI execution, CRM/workflow modernization, controls, adoption, and operating leverage conversations, connect on LinkedIn.</p>
        </div>
        <a class="button" href="https://www.linkedin.com/in/chandra-kanojia/" target="_blank" rel="noopener noreferrer">Connect on LinkedIn</a>
      </div>
    </div>
  </section>

  <script define:vars={{ mandates }}>
    const mandateMap = Object.fromEntries(mandates.map((item) => [item.id, item]));
    const buttons = document.querySelectorAll('.studio-option');
    const title = document.getElementById('studio-output-title');
    const issue = document.getElementById('studio-issue');
    const where = document.getElementById('studio-where');
    const design = document.getElementById('studio-design');
    const leaders = document.getElementById('studio-leaders');
    const board = document.getElementById('studio-board');

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const selected = mandateMap[button.dataset.mandate];
        if (!selected) return;
        buttons.forEach((item) => {
          item.classList.remove('active');
          item.setAttribute('aria-selected', 'false');
        });
        button.classList.add('active');
        button.setAttribute('aria-selected', 'true');
        title.textContent = selected.title;
        issue.textContent = selected.issue;
        where.textContent = selected.where;
        design.textContent = selected.design;
        leaders.textContent = selected.leaders;
        board.textContent = selected.board;
      });
    });
  </script>
</PageLayout>
