---
import PageLayout from '../layouts/PageLayout.astro';

const webpageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://chandrakanojia.com/enterprise-ai-transformation/#webpage',
  url: 'https://chandrakanojia.com/enterprise-ai-transformation',
  name: 'Enterprise AI Operating Model | Chandra Kanojia',
  description: 'A board-level point of view on enterprise AI, governed execution, human-agent workflow, and regulated operating-model change.',
  isPartOf: { '@id': 'https://chandrakanojia.com/#website' },
  about: { '@id': 'https://chandrakanojia.com/#person' }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://chandrakanojia.com' },
    { '@type': 'ListItem', position: 2, name: 'Enterprise AI', item: 'https://chandrakanojia.com/enterprise-ai-transformation' }
  ]
};
---
<PageLayout
  title="Enterprise AI Operating Model | Chandra Kanojia"
  description="A board-level point of view on enterprise AI, governed execution, human-agent workflow, and regulated operating-model change."
  canonical="https://chandrakanojia.com/enterprise-ai-transformation"
  jsonLd={[webpageSchema, breadcrumbSchema]}
>
  <section class="page-hero" aria-labelledby="ai-title">
    <div class="container narrow">
      <p class="kicker">Enterprise AI Point of View</p>
      <h1 id="ai-title">AI transformation is moving from assistance to execution.</h1>
      <p class="lead">
        Enterprise AI is not only a technology question. It is an operating-model question: how work moves, how decisions are controlled, and how outcomes are governed inside regulated institutions.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="mandate-title">
    <div class="container narrow">
      <p class="kicker">The Agentic Enterprise Mandate</p>
      <h2 id="mandate-title">The frontier is not more copilots.</h2>
      <p class="body-large" style="margin-top:1rem;">
        The next frontier will be defined by how well the enterprise redesigns work so humans and agents can operate from the same context, permissions, workflows, controls, and outcome measures.
      </p>
      <p class="body-large" style="margin-top:1rem;">
        The advantage is not model access. The advantage is converting enterprise knowledge, policy, data, and judgment into governed execution at scale.
      </p>
    </div>
  </section>

  <section class="section alt" aria-labelledby="board-title">
    <div class="container narrow">
      <div class="board-memo">
        <p class="kicker">Board question</p>
        <h2 id="board-title">Can management convert AI spend into operating advantage?</h2>
        <p class="body-large" style="margin-top:1rem;">
          The board-level question is no longer whether the technology can produce capability. The question is whether management can govern the investment, redesign the work, control the risk, protect trust, and create measurable operating advantage.
        </p>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="principles-title">
    <div class="container">
      <div class="section-heading">
        <div class="intro">
          <p class="kicker">Operating principles</p>
          <h2 id="principles-title">Controlled intelligence beats AI theater.</h2>
        </div>
      </div>
      <div class="principles">
        <article class="principle"><p>The flashy demo is autonomy. The durable product is controlled autonomy.</p></article>
        <article class="principle"><p>Long context is not memory. Evidence discipline is the control.</p></article>
        <article class="principle"><p>Benchmarks are not work. Work has politics, risk, format, approval, and cleanup cost.</p></article>
        <article class="principle"><p>The next moat is not prompt engineering. It is workflow ownership.</p></article>
      </div>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="ai-cta">
    <div class="container narrow">
      <div class="cta-box">
        <h2 id="ai-cta">Enterprise AI requires operating proof.</h2>
        <p>For board, CXO, consulting, and regulated-enterprise AI conversations, connect directly on LinkedIn.</p>
        <a class="button" href="https://www.linkedin.com/in/chandra-kanojia/" target="_blank" rel="noopener noreferrer">Connect on LinkedIn</a>
      </div>
    </div>
  </section>
</PageLayout>
