---
import PageLayout from '../layouts/PageLayout.astro';
---
<PageLayout
  title="Privacy | Chandra Kanojia"
  description="Privacy information for chandrakanojia.com. This site does not run advertising or behavioral tracking."
  canonical="https://chandrakanojia.com/privacy"
>
  <section class="page-hero" aria-labelledby="privacy-title">
    <div class="container narrow">
      <p class="kicker">Privacy</p>
      <h1 id="privacy-title">Simple by design.</h1>
      <p class="lead">This site does not run advertising, behavioral tracking, or a contact form. Conversations are directed through LinkedIn.</p>
    </div>
  </section>
  <section class="section">
    <div class="container prose-container prose">
      <h2>What this site collects</h2>
      <p>This site does not use cookies, advertising networks, or behavioral tracking systems. No personal contact information is collected or stored by this site.</p>
      <h2>External services</h2>
      <p>This site may load fonts from Google Fonts. Google may process requests to its servers in accordance with its privacy policy.</p>
      <h2>Contact</h2>
      <p>Questions about this site can be directed through the <a href="/contact">contact page</a>.</p>
    </div>
  </section>
</PageLayout>
